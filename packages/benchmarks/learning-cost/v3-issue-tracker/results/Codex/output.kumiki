type IssueId = nominal Text where uuid
type Status = Open | InProgress | Done
type Priority = Low | Med | High
type ThemeChoice = Light | Dark
type Issue = {id: IssueId, title: Text, body: Text, status: Status, priority: Priority, assignee: Text, tags: List(Text), createdAt: Time, updatedAt: Time}
type Comment = {id: Text, issueId: IssueId, author: Text, body: Text, createdAt: Time}
type FilterState = {status: Option(Status), priority: Option(Priority), search: Text}
type DraftIssue = {title: Text, body: Text, priority: Priority, assignee: Text, tags: Text}
type SelectOption(T) = {label: Text, value: T}

slot issues : Map(IssueId, Issue) = {}
slot comments : Map(Text, Comment) = {}
slot filter : FilterState = {status=None, priority=None, search=""}
slot currentUser : Text = "me"
slot draft : DraftIssue = {title="", body="", priority=Med, assignee="", tags=""}
slot commentDraft : Text = ""
slot tagDraft : Text = ""
slot themeName : Text = "Light"

effect saveIssues
    cap=storage.write
    in=Map(IssueId, Issue)
    out=Result(Unit, Text)
    policy=debounce(300ms)
    map-request={key: "kumiki-issues", value: $1}

effect saveComments
    cap=storage.write
    in=Map(Text, Comment)
    out=Result(Unit, Text)
    policy=debounce(300ms)
    map-request={key: "kumiki-comments", value: $1}

effect loadIssues
    cap=storage.read
    in=Unit
    out=Result(Option(Map(IssueId, Issue)), Text)
    policy=once
    map-request={key: "kumiki-issues", decode: Decoder.Json(Map(IssueId, Issue))}

effect loadComments
    cap=storage.read
    in=Unit
    out=Result(Option(Map(Text, Comment)), Text)
    policy=once
    map-request={key: "kumiki-comments", decode: Decoder.Json(Map(Text, Comment))}

reducer loadFromStorage
    on=app.start
    do= emit loadIssues()
        emit loadComments()

reducer issuesLoaded
    on=loadIssues.ok($loaded, $key)
    do= issues := $loaded.get-or({})

reducer commentsLoaded
    on=loadComments.ok($loaded, $key)
    do= comments := $loaded.get-or({})

reducer ignoreLoadIssuesError
    on=loadIssues.err($err, $key)
    do= ()

reducer ignoreLoadCommentsError
    on=loadComments.err($err, $key)
    do= ()

reducer ignoreSaveIssues
    on=saveIssues.ok($unit, $key)
    do= ()

reducer ignoreSaveComments
    on=saveComments.ok($unit, $key)
    do= ()

reducer ignoreSaveIssuesError
    on=saveIssues.err($err, $key)
    do= ()

reducer ignoreSaveCommentsError
    on=saveComments.err($err, $key)
    do= ()

reducer createIssue
    on=ui.submit(NewIssueForm)
    do= let newId = IssueId.fresh()
        let cleanTitle = draft.title.trim
        let cleanAssignee = draft.assignee.trim
        issues[newId] := {id: newId, title: if cleanTitle.is-empty then "Untitled issue" else cleanTitle, body: draft.body.trim, status: Open, priority: draft.priority, assignee: if cleanAssignee.is-empty then currentUser else cleanAssignee, tags: parseTags(draft.tags), createdAt: now, updatedAt: now}
        draft := {title="", body="", priority=Med, assignee="", tags=""}
        emit saveIssues(issues)
        emit navigate({path: "/issues/{id}", params: {"id": newId.show}, query: {}})

reducer updateStatus
    on=ui.change(StatusSelect)
    do= match routeIssueId(route) with
          | Some(issueId) -> { issues[issueId].status := $event.value; issues[issueId].updatedAt := now; emit saveIssues(issues) }
          | None -> ()

reducer updatePriority
    on=ui.change(PrioritySelect)
    do= match routeIssueId(route) with
          | Some(issueId) -> { issues[issueId].priority := $event.value; issues[issueId].updatedAt := now; emit saveIssues(issues) }
          | None -> ()

reducer updateAssignee
    on=ui.input(AssigneeInput)
    do= match routeIssueId(route) with
          | Some(issueId) -> { issues[issueId].assignee := $event.value; issues[issueId].updatedAt := now; emit saveIssues(issues) }
          | None -> ()

reducer addTag
    on=ui.submit(TagForm)
    do= match routeIssueId(route) with
          | Some(issueId) -> { issues[issueId].tags := addCleanTag(issues[issueId].tags, tagDraft); issues[issueId].updatedAt := now; tagDraft := ""; emit saveIssues(issues) }
          | None -> ()

reducer removeTag
    on=ui.click(RemoveTagBtn)
    do= match routeIssueId(route) with
          | Some(issueId) -> { issues[issueId].tags := issues[issueId].tags.filter($1 != $el.tag); issues[issueId].updatedAt := now; emit saveIssues(issues) }
          | None -> ()

reducer addComment
    on=ui.submit(CommentForm)
    do= match routeIssueId(route) with
          | Some(issueId) -> { let cid = "comment-" + now.show; comments[cid] := {id: cid, issueId: issueId, author: currentUser, body: commentDraft.trim, createdAt: now}; commentDraft := ""; emit saveComments(comments) }
          | None -> ()

reducer deleteComment
    on=ui.click(DeleteCommentBtn)
    do= comments := comments.remove($el.commentId)
        emit saveComments(comments)

reducer deleteIssue
    on=ui.click(DeleteIssueBtn)
    do= match routeIssueId(route) with
          | Some(issueId) -> { issues := issues.remove(issueId); for cid in comments.keys { if comments[cid].issueId == issueId then comments := comments.remove(cid) else () }; emit saveIssues(issues); emit saveComments(comments); emit navigate({path: "/", params: {}, query: {}}) }
          | None -> emit navigate({path: "/", params: {}, query: {}})

reducer setFilterStatus
    on=ui.change(FilterStatusSelect)
    do= filter.status := $event.value

reducer setFilterPriority
    on=ui.change(FilterPrioritySelect)
    do= filter.priority := $event.value

reducer setSearch
    on=ui.input(SearchInput)
    do= filter.search := $event.value

reducer clearFilter
    on=ui.click(ClearFilterBtn)
    do= filter := {status=None, priority=None, search=""}

reducer toggleTheme
    on=ui.click(ThemeToggleBtn)
    do= themeName := if themeName == "Light" then "Dark" else "Light"

fn statusOptions() -> List(SelectOption(Status))
    = [{label: "Open", value: Open}, {label: "In Progress", value: InProgress}, {label: "Done", value: Done}]

fn maybeStatusOptions() -> List(SelectOption(Option(Status)))
    = [{label: "Any status", value: None}, {label: "Open", value: Some(Open)}, {label: "In Progress", value: Some(InProgress)}, {label: "Done", value: Some(Done)}]

fn priorityOptions() -> List(SelectOption(Priority))
    = [{label: "Low", value: Low}, {label: "Medium", value: Med}, {label: "High", value: High}]

fn maybePriorityOptions() -> List(SelectOption(Option(Priority)))
    = [{label: "Any priority", value: None}, {label: "Low", value: Some(Low)}, {label: "Medium", value: Some(Med)}, {label: "High", value: Some(High)}]

fn statusLabel(s: Status) -> Text
    = match s with
        | Open -> "Open"
        | InProgress -> "In Progress"
        | Done -> "Done"

fn priorityLabel(p: Priority) -> Text
    = match p with
        | Low -> "Low"
        | Med -> "Medium"
        | High -> "High"

fn priorityColor(p: Priority) -> Text
    = match p with
        | Low -> "muted"
        | Med -> "primary"
        | High -> "danger"

fn statusColor(s: Status) -> Text
    = match s with
        | Open -> "warning"
        | InProgress -> "primary"
        | Done -> "success"

fn matchesFilter(issue: Issue, f: FilterState) -> Bool
    = matchesStatus(issue, f.status) & matchesPriority(issue, f.priority) & matchesSearch(issue, f.search)

fn matchesStatus(issue: Issue, s: Option(Status)) -> Bool
    = match s with
        | Some(target) -> issue.status == target
        | None -> true

fn matchesPriority(issue: Issue, p: Option(Priority)) -> Bool
    = match p with
        | Some(target) -> issue.priority == target
        | None -> true

fn matchesSearch(issue: Issue, q: Text) -> Bool
    = q.trim.is-empty | issue.title.lower.contains(q.trim.lower) | issue.body.lower.contains(q.trim.lower) | issue.assignee.lower.contains(q.trim.lower) | issue.tags.join(",").lower.contains(q.trim.lower)

fn filteredIssues(all: Map(IssueId, Issue), f: FilterState) -> List(IssueId)
    = all.entries.filter(matchesFilter($2, f)).sort-by($2.updatedAt).reverse.map($1)

fn commentsForIssue(all: Map(Text, Comment), issueId: IssueId) -> List(Text)
    = all.entries.filter($2.issueId == issueId).sort-by($2.createdAt).map($1)

fn routeIssueId(r: Route) -> Option(IssueId)
    = IssueId.parse(r.params.get-or("id", ""))

fn currentIssue(r: Route, all: Map(IssueId, Issue)) -> Option(Issue)
    = match routeIssueId(r) with
        | Some(id) -> all.get(id)
        | None -> None

fn formatDate(t: Time) -> Text
    = t.format("yyyy-MM-dd HH:mm")

fn parseTags(text: Text) -> List(Text)
    = text.split(",").map($1.trim).filter(!$1.is-empty).unique

fn addCleanTag(tags: List(Text), tag: Text) -> List(Text)
    = if tag.trim.is-empty then tags else tags.push(tag.trim).unique

theme Light = {
    colors: {
        bg: "#ffffff",
        fg: "#1f2937",
        muted: "#6b7280",
        primary: "#2563eb",
        success: "#15803d",
        warning: "#b45309",
        danger: "#b91c1c",
        surface: "#f8fafc",
        border: "#d1d5db"
    },
    spacing: {
        xs: "4px",
        sm: "8px",
        md: "16px",
        lg: "24px",
        xl: "40px"
    },
    radius: {
        none: "0",
        sm: "4px",
        md: "8px",
        lg: "16px",
        pill: "999px"
    },
    typography: {
        family: "system-ui, sans-serif",
        size: {
            xs: "12px",
            sm: "14px",
            md: "16px",
            lg: "20px",
            xl: "28px"
        },
        weight: {
            normal: "400",
            medium: "500",
            bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm: "0 1px 2px rgba(15,23,42,0.08)",
        md: "0 6px 18px rgba(15,23,42,0.12)"
    },
    breakpoints: {
        sm: "640px",
        md: "768px",
        lg: "1024px",
        xl: "1280px"
    }
}

theme Dark = {
    colors: {
        bg: "#111827",
        fg: "#f9fafb",
        muted: "#9ca3af",
        primary: "#60a5fa",
        success: "#34d399",
        warning: "#fbbf24",
        danger: "#f87171",
        surface: "#1f2937",
        border: "#374151"
    },
    spacing: {
        xs: "4px",
        sm: "8px",
        md: "16px",
        lg: "24px",
        xl: "40px"
    },
    radius: {
        none: "0",
        sm: "4px",
        md: "8px",
        lg: "16px",
        pill: "999px"
    },
    typography: {
        family: "system-ui, sans-serif",
        size: {
            xs: "12px",
            sm: "14px",
            md: "16px",
            lg: "20px",
            xl: "28px"
        },
        weight: {
            normal: "400",
            medium: "500",
            bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm: "0 1px 2px rgba(0,0,0,0.25)",
        md: "0 6px 18px rgba(0,0,0,0.35)"
    },
    breakpoints: {
        sm: "640px",
        md: "768px",
        lg: "1024px",
        xl: "1280px"
    }
}

tile App = IssueListPage

tile Shell
    in=Text
    = page(
        column(
            HeaderBar,
            $1
        ) {gap: "lg"}
    ) {title: "Issue Tracker", bg: "bg", color: "fg", pad: {base: "md", lg: "xl"}}

tile HeaderBar = row(
    row(
        heading("Issue Tracker") {level: 1, size: "xl"},
        link(to="/") {text: "Issues"},
        link(to="/new") {text: "New"},
        link(to="/settings") {text: "Settings"}
    ) {gap: "md", align: "center", wrap: true},
    text("Signed in as " + currentUser) {color: "muted"}
) {justify: "between", align: "center", gap: "md", wrap: true}

tile IssueListPage = page(
    column(
        HeaderBar,
        row(
            heading("Issues") {level: 2},
            link(to="/new") {text: "New Issue", bg: "primary", color: "bg", pad: "sm", radius: "sm"}
        ) {justify: "between", align: "center", gap: "md"},
        FilterBar,
        IssueList
    ) {gap: "lg"}
) {title: "Issues", pad: {base: "md", lg: "xl"}, bg: "bg", color: "fg"}

tile FilterBar = panel(
    column(
        row(
            FilterStatusSelect,
            FilterPrioritySelect,
            SearchInput,
            ClearFilterBtn
        ) {gap: "sm", align: "end", wrap: true},
        row(
            text("Showing " + filteredIssues(issues, filter).length.show + " of " + issues.size.show + " issues") {color: "muted"},
            when(!(filter.search.trim.is-empty), text("Search: " + filter.search) {color: "primary"})
        ) {gap: "md", wrap: true}
    ) {gap: "sm"}
) {pad: "md", bg: "surface", radius: "md"}

tile FilterStatusSelect = select(
    bind=filter.status,
    options=maybeStatusOptions(),
    placeholder="Status"
) {w: 180}

tile FilterPrioritySelect = select(
    bind=filter.priority,
    options=maybePriorityOptions(),
    placeholder="Priority"
) {w: 180}

tile SearchInput = input(
    bind=filter.search,
    type="search",
    placeholder="Search issues",
    onInput=setSearch
) {w: 280}

tile ClearFilterBtn = button(text="Clear", onClick=clearFilter) {variant: "ghost"}

tile IssueList = if issues.is-empty then EmptyIssueState else column(
    for issueId in filteredIssues(issues, filter)
        IssueCard(issueId) {key: issueId.show}
) {gap: "md"}

tile EmptyIssueState = panel(
    column(
        heading("No issues") {level: 3},
        text("Create the first issue to start tracking work.") {color: "muted"},
        link(to="/new") {text: "Create issue", bg: "primary", color: "bg", pad: "sm", radius: "sm"}
    ) {gap: "sm", align: "start"}
) {pad: "lg", bg: "surface", radius: "md"}

tile IssueCard
    in=IssueId
    = card(
        column(
            row(
                link(to="/issues/" + $1.show) {text: issues[$1].title},
                row(
                    StatusBadge(issues[$1].status),
                    PriorityBadge(issues[$1].priority)
                ) {gap: "xs"}
            ) {justify: "between", align: "center", gap: "md", wrap: true},
            text(issues[$1].body) {color: "muted"},
            row(
                text("Assignee: " + issues[$1].assignee) {size: "sm", color: "muted"},
                text("Updated " + formatDate(issues[$1].updatedAt)) {size: "sm", color: "muted"}
            ) {gap: "md", wrap: true},
            TagList($1)
        ) {gap: "sm"}
    ) {pad: "md", bg: "surface", radius: "md", shadow: "sm"}

tile StatusBadge
    in=Status
    = text(statusLabel($1)) {color: statusColor($1), size: "sm", weight: "bold"}

tile PriorityBadge
    in=Priority
    = text(priorityLabel($1)) {color: priorityColor($1), size: "sm", weight: "bold"}

tile TagList
    in=IssueId
    = row(
        for tag in issues[$1].tags
            text("#" + tag) {key: tag, size: "sm", color: "primary", bg: "bg", pad-x: "sm", pad-y: "xs", radius: "pill"}
    ) {gap: "xs", wrap: true}

tile IssueDetailPage = match currentIssue(route, issues) with
    | Some(issue) -> IssueDetail(issue.id)
    | None -> MissingIssue

tile MissingIssue = page(
    column(
        HeaderBar,
        panel(
            column(
                heading("Issue not found") {level: 2},
                text("The issue may have been deleted or the URL is invalid.") {color: "muted"},
                link(to="/") {text: "Back to issues"}
            ) {gap: "sm"}
        ) {pad: "lg", bg: "surface", radius: "md"}
    ) {gap: "lg"}
) {title: "Issue not found", pad: {base: "md", lg: "xl"}, bg: "bg", color: "fg"}

tile IssueDetail
    in=IssueId
    = page(
        column(
            HeaderBar,
            row(
                link(to="/") {text: "Back"},
                DeleteIssueBtn
            ) {justify: "between", align: "center"},
            panel(
                column(
                    row(
                        heading(issues[$1].title) {level: 2},
                        row(StatusBadge(issues[$1].status), PriorityBadge(issues[$1].priority)) {gap: "xs"}
                    ) {justify: "between", align: "center", gap: "md", wrap: true},
                    markdown(issues[$1].body),
                    row(
                        text("Created " + formatDate(issues[$1].createdAt)) {color: "muted", size: "sm"},
                        text("Updated " + formatDate(issues[$1].updatedAt)) {color: "muted", size: "sm"}
                    ) {gap: "md", wrap: true},
                    DetailEditor,
                    divider(),
                    DetailTags($1)
                ) {gap: "md"}
            ) {pad: "lg", bg: "surface", radius: "md"},
            CommentsPanel($1)
        ) {gap: "lg"}
    ) {title: issues[$1].title, pad: {base: "md", lg: "xl"}, bg: "bg", color: "fg"}

tile DetailEditor = grid(
    column(label("Status") {for: "detail-status"}, StatusSelect) {gap: "xs"},
    column(label("Priority") {for: "detail-priority"}, PrioritySelect) {gap: "xs"},
    column(label("Assignee") {for: "detail-assignee"}, AssigneeInput) {gap: "xs"}
) {cols: {base: 1, md: 3}, gap: "md"}

tile StatusSelect = match routeIssueId(route) with
    | Some(issueId) -> select(value=issues[issueId].status, options=statusOptions(), placeholder="Status", onChange=updateStatus) {id: "detail-status"}
    | None -> select(value=Open, options=statusOptions(), placeholder="Status", disabled=true) {id: "detail-status"}

tile PrioritySelect = match routeIssueId(route) with
    | Some(issueId) -> select(value=issues[issueId].priority, options=priorityOptions(), placeholder="Priority", onChange=updatePriority) {id: "detail-priority"}
    | None -> select(value=Med, options=priorityOptions(), placeholder="Priority", disabled=true) {id: "detail-priority"}

tile AssigneeInput = match routeIssueId(route) with
    | Some(issueId) -> input(value=issues[issueId].assignee, placeholder="Assignee", onInput=updateAssignee) {id: "detail-assignee"}
    | None -> input(value="", placeholder="Assignee", disabled=true) {id: "detail-assignee"}

tile DetailTags
    in=IssueId
    = column(
        row(
            for tag in issues[$1].tags
                row(
                    text("#" + tag) {size: "sm", color: "primary"},
                    RemoveTagBtn(tag)
                ) {key: tag, gap: "xs", align: "center", bg: "bg", pad-x: "sm", pad-y: "xs", radius: "pill"}
        ) {gap: "xs", wrap: true},
        TagForm
    ) {gap: "sm"}

tile RemoveTagBtn
    in=Text
    = button(text="Remove", onClick=removeTag) {tag: $1, variant: "ghost", size: "sm"}

tile TagForm = form(
    row(
        input(bind=tagDraft, placeholder="Add tag") {id: "tag-input"},
        button(text="Add tag", type="submit", disabled=tagDraft.trim.is-empty)
    ) {gap: "sm", align: "center", wrap: true}
)

tile DeleteIssueBtn = button(text="Delete issue", onClick=deleteIssue) {bg: "danger", color: "bg"}

tile CommentsPanel
    in=IssueId
    = panel(
        column(
            heading("Comments") {level: 3},
            if commentsForIssue(comments, $1).is-empty then text("No comments yet.") {color: "muted"} else column(
                for commentId in commentsForIssue(comments, $1)
                    CommentCard(commentId) {key: commentId}
            ) {gap: "sm"},
            CommentForm
        ) {gap: "md"}
    ) {pad: "lg", bg: "surface", radius: "md"}

tile CommentCard
    in=Text
    = card(
        column(
            row(
                text(comments[$1].author + " commented " + formatDate(comments[$1].createdAt)) {size: "sm", color: "muted"},
                DeleteCommentBtn($1)
            ) {justify: "between", align: "center", gap: "md"},
            markdown(comments[$1].body)
        ) {gap: "sm"}
    ) {pad: "md", bg: "bg", radius: "md"}

tile DeleteCommentBtn
    in=Text
    = button(text="Delete", onClick=deleteComment) {commentId: $1, variant: "ghost"}

tile CommentForm = form(
    column(
        label("New comment") {for: "comment-body"},
        textarea(bind=commentDraft, rows=4, placeholder="Write a comment") {id: "comment-body"},
        button(text="Comment", type="submit", disabled=commentDraft.trim.is-empty) {bg: "primary", color: "bg"}
    ) {gap: "sm", align: "start"}
)

tile NewIssuePage = page(
    column(
        HeaderBar,
        row(
            heading("New Issue") {level: 2},
            link(to="/") {text: "Cancel"}
        ) {justify: "between", align: "center"},
        NewIssueForm
    ) {gap: "lg"}
) {title: "New Issue", pad: {base: "md", lg: "xl"}, bg: "bg", color: "fg"}

tile NewIssueForm = form(
    panel(
        column(
            column(
                label("Title") {for: "new-title"},
                input(bind=draft.title, placeholder="Short summary", required=true, auto-focus=true) {id: "new-title"},
                error(field=draft.title)
            ) {gap: "xs"},
            column(
                label("Body") {for: "new-body"},
                textarea(bind=draft.body, rows=8, placeholder="Describe the problem or request") {id: "new-body"}
            ) {gap: "xs"},
            grid(
                column(label("Priority") {for: "new-priority"}, NewPrioritySelect) {gap: "xs"},
                column(label("Assignee") {for: "new-assignee"}, input(bind=draft.assignee, placeholder=currentUser) {id: "new-assignee"}) {gap: "xs"}
            ) {cols: {base: 1, md: 2}, gap: "md"},
            column(
                label("Tags") {for: "new-tags"},
                input(bind=draft.tags, placeholder="bug, frontend, urgent") {id: "new-tags"}
            ) {gap: "xs"},
            row(
                button(text="Create issue", type="submit", disabled=draft.title.trim.is-empty) {bg: "primary", color: "bg"},
                link(to="/") {text: "Cancel"}
            ) {gap: "sm", align: "center"}
        ) {gap: "md"}
    ) {pad: "lg", bg: "surface", radius: "md"}
)

tile NewPrioritySelect = select(bind=draft.priority, options=priorityOptions(), placeholder="Priority") {id: "new-priority"}

tile SettingsPage = page(
    column(
        HeaderBar,
        panel(
            column(
                heading("Settings") {level: 2},
                text("Theme") {weight: "bold"},
                row(
                    text("Current theme: " + themeName),
                    ThemeToggleBtn
                ) {gap: "md", align: "center", wrap: true}
            ) {gap: "md"}
        ) {pad: "lg", bg: "surface", radius: "md"}
    ) {gap: "lg"}
) {title: "Settings", pad: {base: "md", lg: "xl"}, bg: "bg", color: "fg"}

tile ThemeToggleBtn = button(text=if themeName == "Light" then "Switch to Dark" else "Switch to Light", onClick=toggleTheme) {bg: "primary", color: "bg"}

tile NotFound = page(
    column(
        HeaderBar,
        panel(
            column(
                heading("404") {level: 2},
                text("Page not found") {color: "muted"},
                link(to="/") {text: "Back to issues"}
            ) {gap: "sm"}
        ) {pad: "lg", bg: "surface", radius: "md"}
    ) {gap: "lg"}
) {title: "Not Found", pad: {base: "md", lg: "xl"}, bg: "bg", color: "fg"}

app IssueTracker
    caps=[storage.read, storage.write, nav.push, nav.replace]
    routes={
        "/" -> IssueListPage,
        "/issues/:id" -> IssueDetailPage,
        "/new" -> NewIssuePage,
        "/settings" -> SettingsPage,
        "/404" -> NotFound
    }
    init=[]
    theme=themeName
