# Feature: `if ... then ... else` as a value expression (not a statement).

slot n : Int = 0

reducer bump on=ui.click(BumpBtn) do= n := n + 1

tile BumpBtn = button(text="+1", onClick=bump)
tile App = column(
             heading(if n == 0 then "zero"
                     else if n > 0 then "positive"
                     else "negative"),
             text("n = " + n.show),
             BumpBtn)

app IfExpression
    caps   = []
    routes = {"/" -> App, "/404" -> App}
    init   = []
