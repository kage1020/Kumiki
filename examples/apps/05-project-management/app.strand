# Project Management Tool — Strand v0.1
# Asana / Linear-like SPA. Demonstrates: routing, storage, lifecycle, theme switching,
# nested forms, list+board views, comments, tags, sub-tasks.

# ====== Types ======

type ProjectId = nominal Text where uuid
type TaskId    = nominal Text where uuid
type CommentId = nominal Text where uuid

type Status   = Backlog | InProgress | Review | Done
type Priority = Low | Med | High | Critical
type ViewMode = ListView | BoardView

type Project = {
    id: ProjectId,
    name: Text,
    description: Text,
    color: Text,
    archived: Bool,
    createdAt: Time
}

type Task = {
    id: TaskId,
    projectId: ProjectId,
    title: Text,
    description: Text,
    status: Status,
    priority: Priority,
    assignee: Text,
    dueDate: Option(Time),
    tags: List(Text),
    parentTaskId: Option(TaskId),
    createdAt: Time,
    updatedAt: Time
}

type Comment = {
    id: CommentId,
    taskId: TaskId,
    author: Text,
    body: Text,
    createdAt: Time
}

type FilterState = {
    status: Option(Status),
    priority: Option(Priority),
    assignee: Text,
    search: Text
}

type DraftProject = {
    name: Text,
    description: Text,
    color: Text
}

type DraftTask = {
    title: Text,
    description: Text,
    priority: Priority,
    assignee: Text,
    tags: Text,
    dueDate: Text
}

type DueStatus = Overdue | DueToday | DueSoon | DueUpcoming | NoDue

# ====== Slots ======

slot projects     : Map(ProjectId, Project)  = {}
slot tasks        : Map(TaskId, Task)        = {}
slot comments     : Map(CommentId, Comment)  = {}

slot viewMode     : ViewMode                 = ListView
slot filter       : FilterState              = {status: None, priority: None, assignee: "", search: ""}

slot themeName    : Text                     = "Light"

slot draftProject : DraftProject             = {name: "", description: "", color: "#0070f3"}
slot draftTask    : DraftTask                = {title: "", description: "", priority: Med, assignee: "", tags: "", dueDate: ""}

slot commentDraft : Text                     = ""

slot ready        : Bool                     = false

# ====== Effects: Storage ======

effect loadProjects cap=storage.read
                    in=Unit
                    out=Result(Option(Map(ProjectId, Project)), Text)
                    policy=once
                    map-request={key: "pm.projects", decode: Decoder.Json(Map(ProjectId, Project))}

effect loadTasks    cap=storage.read
                    in=Unit
                    out=Result(Option(Map(TaskId, Task)), Text)
                    policy=once
                    map-request={key: "pm.tasks", decode: Decoder.Json(Map(TaskId, Task))}

effect loadComments cap=storage.read
                    in=Unit
                    out=Result(Option(Map(CommentId, Comment)), Text)
                    policy=once
                    map-request={key: "pm.comments", decode: Decoder.Json(Map(CommentId, Comment))}

effect saveProjects cap=storage.write
                    in=Map(ProjectId, Project)
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.projects", value: $1}

effect saveTasks    cap=storage.write
                    in=Map(TaskId, Task)
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.tasks", value: $1}

effect saveComments cap=storage.write
                    in=Map(CommentId, Comment)
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.comments", value: $1}

effect loadTheme    cap=storage.read
                    in=Unit
                    out=Result(Option(Text), Text)
                    policy=once
                    map-request={key: "pm.theme", decode: Decoder.Json(Text)}

effect saveTheme    cap=storage.write
                    in=Text
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.theme", value: $1}

# ====== Pure Fns ======

fn statusLabel(s: Status) -> Text
   = match s with
       | Backlog    -> "Backlog"
       | InProgress -> "In Progress"
       | Review     -> "Review"
       | Done       -> "Done"

fn statusColor(s: Status) -> Text
   = match s with
       | Backlog    -> "muted"
       | InProgress -> "primary"
       | Review     -> "warning"
       | Done       -> "success"

fn priorityLabel(p: Priority) -> Text
   = match p with
       | Low      -> "Low"
       | Med      -> "Medium"
       | High     -> "High"
       | Critical -> "Critical"

fn priorityColor(p: Priority) -> Text
   = match p with
       | Low      -> "muted"
       | Med      -> "fg"
       | High     -> "warning"
       | Critical -> "danger"

fn formatDate(t: Time) -> Text
   = t.format("yyyy-MM-dd")

fn formatDateTime(t: Time) -> Text
   = t.format("yyyy-MM-dd HH:mm")

fn dueDateStatus(d: Option(Time)) -> DueStatus
   = match d with
       | None     -> NoDue
       | Some(t)  -> let diffMs = t.diff(now).to-ms
                     in if diffMs < 0 then Overdue
                        else if diffMs < 86400000 then DueToday
                        else if diffMs < 259200000 then DueSoon
                        else DueUpcoming

fn dueStatusLabel(d: DueStatus) -> Text
   = match d with
       | Overdue     -> "Overdue"
       | DueToday    -> "Today"
       | DueSoon     -> "Soon"
       | DueUpcoming -> "Upcoming"
       | NoDue       -> "No due date"

fn dueStatusColor(d: DueStatus) -> Text
   = match d with
       | Overdue     -> "danger"
       | DueToday    -> "warning"
       | DueSoon     -> "warning"
       | DueUpcoming -> "muted"
       | NoDue       -> "muted"

fn parseTags(text: Text) -> List(Text)
   = text.split(",").map($1.trim).filter(not $1.is-empty)

fn tagsToText(tags: List(Text)) -> Text
   = tags.join(", ")

fn parseDueDate(text: Text) -> Option(Time)
   = if text.is-empty then None else Time.parse(text)

fn taskMatchesFilter(t: Task, f: FilterState) -> Bool
   = let statusOk = match f.status with
                       | None    -> true
                       | Some(s) -> t.status == s
     in let priorityOk = match f.priority with
                            | None    -> true
                            | Some(p) -> t.priority == p
        in let assigneeOk = f.assignee.is-empty || t.assignee.lower.contains(f.assignee.lower)
           in let searchOk = f.search.is-empty || t.title.lower.contains(f.search.lower) || t.description.lower.contains(f.search.lower)
              in statusOk && priorityOk && assigneeOk && searchOk

fn tasksForProject(ts: Map(TaskId, Task), pid: ProjectId) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == pid)
       .sort-by(-$2.updatedAt.to-ms)
       .map($1)

fn subtasksFor(ts: Map(TaskId, Task), parentId: TaskId) -> List(TaskId)
   = ts.entries
       .filter(matchesParent($2, parentId))
       .sort-by($2.createdAt.to-ms)
       .map($1)

fn matchesParent(t: Task, parentId: TaskId) -> Bool
   = match t.parentTaskId with
       | None     -> false
       | Some(id) -> id == parentId

fn isTopLevel(t: Task) -> Bool
   = t.parentTaskId.is-none

fn filteredTasks(ts: Map(TaskId, Task), pid: ProjectId, f: FilterState) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == pid)
       .filter(isTopLevel($2))
       .filter(taskMatchesFilter($2, f))
       .sort-by(-$2.updatedAt.to-ms)
       .map($1)

fn tasksByStatus(ts: Map(TaskId, Task), pid: ProjectId, f: FilterState, st: Status) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == pid)
       .filter(isTopLevel($2))
       .filter(taskMatchesFilter($2, f))
       .filter($2.status == st)
       .sort-by(-$2.updatedAt.to-ms)
       .map($1)

fn commentsForTask(cs: Map(CommentId, Comment), tid: TaskId) -> List(CommentId)
   = cs.entries
       .filter($2.taskId == tid)
       .sort-by($2.createdAt.to-ms)
       .map($1)

fn projectTaskCount(ts: Map(TaskId, Task), pid: ProjectId) -> Int
   = ts.entries.filter($2.projectId == pid).length

fn projectActiveCount(ts: Map(TaskId, Task), pid: ProjectId) -> Int
   = ts.entries.filter($2.projectId == pid).filter($2.status != Done).length

fn projectDoneCount(ts: Map(TaskId, Task), pid: ProjectId) -> Int
   = ts.entries.filter($2.projectId == pid).filter($2.status == Done).length

fn routeProjectId(r: Route) -> Option(ProjectId)
   = ProjectId.parse(r.params.get-or("id", ""))

fn routeTaskId(r: Route) -> Option(TaskId)
   = TaskId.parse(r.params.get-or("taskId", ""))

fn currentProject(r: Route, ps: Map(ProjectId, Project)) -> Option(Project)
   = match routeProjectId(r) with
       | None      -> None
       | Some(pid) -> ps.get(pid)

fn nextStatus(s: Status) -> Status
   = match s with
       | Backlog    -> InProgress
       | InProgress -> Review
       | Review     -> Done
       | Done       -> Done

fn sortedProjectIds(ps: Map(ProjectId, Project)) -> List(ProjectId)
   = ps.entries.sort-by(-$2.createdAt.to-ms).map($1)

fn activeProjectIds(ps: Map(ProjectId, Project)) -> List(ProjectId)
   = ps.entries.filter(not $2.archived).sort-by(-$2.createdAt.to-ms).map($1)

fn archivedProjectIds(ps: Map(ProjectId, Project)) -> List(ProjectId)
   = ps.entries.filter($2.archived).sort-by(-$2.createdAt.to-ms).map($1)

fn priorityOptions() -> List({label: Text, value: Priority})
   = [{label: "Low", value: Low},
      {label: "Medium", value: Med},
      {label: "High", value: High},
      {label: "Critical", value: Critical}]

fn statusOptions() -> List({label: Text, value: Status})
   = [{label: "Backlog", value: Backlog},
      {label: "In Progress", value: InProgress},
      {label: "Review", value: Review},
      {label: "Done", value: Done}]

fn statusFilterOptions() -> List({label: Text, value: Option(Status)})
   = [{label: "All status", value: None},
      {label: "Backlog", value: Some(Backlog)},
      {label: "In Progress", value: Some(InProgress)},
      {label: "Review", value: Some(Review)},
      {label: "Done", value: Some(Done)}]

fn priorityFilterOptions() -> List({label: Text, value: Option(Priority)})
   = [{label: "All priorities", value: None},
      {label: "Low", value: Some(Low)},
      {label: "Medium", value: Some(Med)},
      {label: "High", value: Some(High)},
      {label: "Critical", value: Some(Critical)}]

# ====== Lifecycle Reducers ======

reducer boot
    on=app.start
    do= emit loadProjects()
        emit loadTasks()
        emit loadComments()
        emit loadTheme()

reducer projectsLoaded
    on=loadProjects.ok($m, _)
    do= projects := $m.get-or({})

reducer tasksLoaded
    on=loadTasks.ok($m, _)
    do= tasks := $m.get-or({})
        ready := true

reducer commentsLoaded
    on=loadComments.ok($m, _)
    do= comments := $m.get-or({})

reducer themeLoaded
    on=loadTheme.ok($m, _)
    do= themeName := $m.get-or("Light")

reducer projectsLoadFailed on=loadProjects.err(_, _) do= projects := {}
reducer tasksLoadFailed    on=loadTasks.err(_, _)    do= tasks := {}
                                                         ready := true
reducer commentsLoadFailed on=loadComments.err(_, _) do= comments := {}

# ====== Reducers: Theme ======

reducer toggleTheme
    on=ui.click(ThemeToggleBtn)
    do= themeName := if themeName == "Light" then "Dark" else "Light"
        emit saveTheme(if themeName == "Light" then "Dark" else "Light")

# ====== Reducers: Projects ======

reducer createProject
    on=ui.submit(NewProjectForm)
    do= let pid = ProjectId.fresh()
        projects[pid] := {
            id: pid,
            name: draftProject.name,
            description: draftProject.description,
            color: draftProject.color,
            archived: false,
            createdAt: now
        }
        draftProject := {name: "", description: "", color: "#0070f3"}
        emit saveProjects(projects)
        emit navigate({path: "/projects/" + pid.show, params: {}, query: {}})

reducer archiveProject
    on=ui.click(ArchiveProjectBtn)
    do= projects[$el.projectId].archived := true
        emit saveProjects(projects)

reducer unarchiveProject
    on=ui.click(UnarchiveProjectBtn)
    do= projects[$el.projectId].archived := false
        emit saveProjects(projects)

reducer deleteProject
    on=ui.click(DeleteProjectBtn)
    do= projects := projects.remove($el.projectId)
        tasks := tasks.filter($2.projectId != $el.projectId)
        comments := comments.filter(commentTaskInProject($2, $el.projectId, tasks))
        emit saveProjects(projects)
        emit saveTasks(tasks)
        emit saveComments(comments)

fn commentTaskInProject(c: Comment, pid: ProjectId, ts: Map(TaskId, Task)) -> Bool
   = match ts.get(c.taskId) with
       | None    -> false
       | Some(t) -> t.projectId != pid

# ====== Reducers: Tasks ======

reducer createTask
    on=ui.submit(NewTaskForm)
    do= match routeProjectId(route) with
            | None      -> ()
            | Some(pid) -> let tid = TaskId.fresh()
                           tasks[tid] := {
                               id: tid,
                               projectId: pid,
                               title: draftTask.title,
                               description: draftTask.description,
                               status: Backlog,
                               priority: draftTask.priority,
                               assignee: draftTask.assignee,
                               dueDate: parseDueDate(draftTask.dueDate),
                               tags: parseTags(draftTask.tags),
                               parentTaskId: None,
                               createdAt: now,
                               updatedAt: now
                           }
                           draftTask := {title: "", description: "", priority: Med, assignee: "", tags: "", dueDate: ""}
                           emit saveTasks(tasks)
                           emit navigate({path: "/projects/" + pid.show + "/tasks/" + tid.show, params: {}, query: {}})

reducer updateTaskStatus
    on=ui.change(TaskStatusSelect)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> tasks[tid].status := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks)

reducer updateTaskPriority
    on=ui.change(TaskPrioritySelect)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> tasks[tid].priority := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks)

reducer updateTaskAssignee
    on=ui.input(TaskAssigneeInput)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> tasks[tid].assignee := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks)

reducer updateTaskDueDate
    on=ui.change(TaskDueDateInput)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> tasks[tid].dueDate := parseDueDate($event.value)
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks)

reducer updateTaskTitle
    on=ui.input(TaskTitleInput)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> tasks[tid].title := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks)

reducer updateTaskDescription
    on=ui.input(TaskDescriptionInput)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> tasks[tid].description := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks)

slot tagDraft : Text = ""

reducer addTaskTag
    on=ui.submit(AddTagForm)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> if tagDraft.trim.is-empty
                           then ()
                           else { tasks[tid].tags := tasks[tid].tags.push(tagDraft.trim).unique;
                                  tasks[tid].updatedAt := now;
                                  tagDraft := "";
                                  emit saveTasks(tasks) }

reducer removeTaskTag
    on=ui.click(RemoveTagBtn)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> tasks[tid].tags := tasks[tid].tags.filter($1 != $el.tagName)
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks)

reducer deleteTask
    on=ui.click(DeleteTaskBtn)
    do= let tid = $el.taskId
        tasks := tasks.remove(tid).filter(taskNotChildOf($2, tid))
        comments := comments.filter($2.taskId != tid)
        emit saveTasks(tasks)
        emit saveComments(comments)

fn taskNotChildOf(t: Task, parentId: TaskId) -> Bool
   = match t.parentTaskId with
       | None    -> true
       | Some(p) -> p != parentId

reducer moveTaskStatus
    on=ui.click(MoveTaskBtn)
    do= tasks[$el.taskId].status := nextStatus(tasks[$el.taskId].status)
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

# ====== Reducers: Comments ======

reducer addComment
    on=ui.submit(AddCommentForm)
    do= match routeTaskId(route) with
            | None      -> ()
            | Some(tid) -> if commentDraft.trim.is-empty
                           then ()
                           else { let cid = CommentId.fresh();
                                  comments[cid] := {
                                      id: cid,
                                      taskId: tid,
                                      author: "Me",
                                      body: commentDraft.trim,
                                      createdAt: now
                                  };
                                  commentDraft := "";
                                  emit saveComments(comments) }

reducer deleteComment
    on=ui.click(DeleteCommentBtn)
    do= comments := comments.remove($el.commentId)
        emit saveComments(comments)

# ====== Reducers: UI / Filter ======

reducer setViewMode
    on=ui.click(ViewModeToggleBtn)
    do= viewMode := if viewMode == ListView then BoardView else ListView

reducer setFilterStatus
    on=ui.change(FilterStatusSelect)
    do= filter.status := $event.value

reducer setFilterPriority
    on=ui.change(FilterPrioritySelect)
    do= filter.priority := $event.value

reducer setFilterAssignee
    on=ui.input(FilterAssigneeInput)
    do= filter.assignee := $event.value

reducer setSearch
    on=ui.input(FilterSearchInput)
    do= filter.search := $event.value

reducer clearFilter
    on=ui.click(ClearFilterBtn)
    do= filter := {status: None, priority: None, assignee: "", search: ""}

# ====== Route Lifecycle ======

reducer onLeaveProject
    on=route.leave("/projects/:id")
    do= filter := {status: None, priority: None, assignee: "", search: ""}

reducer onEnterNewTask
    on=route.enter("/projects/:id/new-task")
    do= draftTask := {title: "", description: "", priority: Med, assignee: "", tags: "", dueDate: ""}

# ====== Tiles: Reusable buttons ======

tile ThemeToggleBtn = button(text="Toggle Theme") {variant: "ghost"}

tile ViewModeToggleBtn
    = button(text=if viewMode == ListView then "Board View" else "List View") {variant: "ghost"}

tile ClearFilterBtn = button(text="Clear filters") {variant: "ghost"}

tile ArchiveProjectBtn   = button(text="Archive") {variant: "ghost"}
tile UnarchiveProjectBtn = button(text="Unarchive") {variant: "ghost"}
tile DeleteProjectBtn    = button(text="Delete") {variant: "ghost", color: "danger"}
tile DeleteTaskBtn       = button(text="Delete task") {variant: "ghost", color: "danger"}
tile MoveTaskBtn         = button(text=">") {variant: "ghost"}
tile RemoveTagBtn        = button(text="x") {variant: "ghost"}
tile DeleteCommentBtn    = button(text="Delete") {variant: "ghost", color: "danger"}

# ====== Tiles: Top nav ======

tile TopNav
    = row(
        link(to="/") {text: "Projects"},
        link(to="/settings") {text: "Settings"},
        ThemeToggleBtn)
      {gap: "md", justify: "between", pad: "md", bg: "surface"}

# ====== Tiles: Projects Page ======

tile ProjectNameInput        = input(bind=draftProject.name, placeholder="Project name", id="proj-name", required=true)
tile ProjectDescriptionInput = textarea(bind=draftProject.description, placeholder="Description", rows=2, id="proj-desc")
tile ProjectColorInput       = input(bind=draftProject.color, type="text", placeholder="#0070f3", id="proj-color")

tile NewProjectForm
    = form(
        column(
          heading("Create new project") {size: "lg"},
          label(text="Name") {for: "proj-name"},
          ProjectNameInput,
          label(text="Description") {for: "proj-desc"},
          ProjectDescriptionInput,
          label(text="Color") {for: "proj-color"},
          ProjectColorInput,
          button(text="Create project", type="submit") {bg: "primary"}
        ) {gap: "sm"}
      ) {pad: "md", bg: "surface", radius: "md"}

tile ProjectCard
    in=ProjectId
    = card(
        column(
          row(
            link(to="/projects/" + $1.show) {text: projects[$1].name, size: "lg", weight: "bold"},
            text(if projects[$1].archived then "Archived" else "") {color: "muted", size: "sm"}
          ) {justify: "between"},
          text(projects[$1].description) {color: "muted"},
          row(
            text(projectActiveCount(tasks, $1).show + " active") {color: "primary", size: "sm"},
            text(projectDoneCount(tasks, $1).show + " done") {color: "success", size: "sm"},
            text(projectTaskCount(tasks, $1).show + " total") {color: "muted", size: "sm"}
          ) {gap: "md"},
          row(
            link(to="/projects/" + $1.show) {text: "Open"},
            if projects[$1].archived
              then UnarchiveProjectBtn {projectId: $1}
              else ArchiveProjectBtn {projectId: $1},
            DeleteProjectBtn {projectId: $1}
          ) {gap: "sm", justify: "end"}
        ) {gap: "sm"}
      ) {pad: "md"}

tile ActiveProjectsSection
    = column(
        heading("Active projects") {size: "lg"},
        if activeProjectIds(projects).is-empty
          then text("No active projects yet. Create your first one above.") {color: "muted"}
          else column(
                 for id in activeProjectIds(projects)
                   ProjectCard(id) {key: id.show}
               ) {gap: "md"}
      ) {gap: "sm"}

tile ArchivedProjectsSection
    = when(not archivedProjectIds(projects).is-empty,
        column(
          heading("Archived projects") {size: "md", color: "muted"},
          column(
            for id in archivedProjectIds(projects)
              ProjectCard(id) {key: id.show}
          ) {gap: "md"}
        ) {gap: "sm"})

tile ProjectsPage
    = page(
        TopNav,
        column(
          heading("Projects") {size: "xxl"},
          NewProjectForm,
          when(ready, ActiveProjectsSection),
          when(ready, ArchivedProjectsSection),
          when(not ready, spinner() {size: "lg"})
        ) {pad: "lg", gap: "lg", max-w: 960}
      )

# ====== Tiles: Filter Bar ======

tile FilterStatusSelect
    = select(
        bind=filter.status,
        options=statusFilterOptions(),
        placeholder="Status")

tile FilterPrioritySelect
    = select(
        bind=filter.priority,
        options=priorityFilterOptions(),
        placeholder="Priority")

tile FilterAssigneeInput
    = input(bind=filter.assignee, placeholder="Assignee", type="text")

tile FilterSearchInput
    = input(bind=filter.search, placeholder="Search title or description", type="search")

tile FilterBar
    = card(
        row(
          FilterSearchInput,
          FilterStatusSelect,
          FilterPrioritySelect,
          FilterAssigneeInput,
          ClearFilterBtn
        ) {gap: "sm", wrap: true, align: "center"}
      ) {pad: "sm", bg: "surface"}

# ====== Tiles: Task Card (List view) ======

tile TaskTagPill
    in=Text
    = text("#" + $1) {color: "primary", size: "sm"}

tile TaskCard
    in=TaskId
    = card(
        column(
          row(
            link(to="/projects/" + tasks[$1].projectId.show + "/tasks/" + $1.show) {
              text: tasks[$1].title, size: "lg", weight: "bold"
            },
            text(statusLabel(tasks[$1].status)) {color: statusColor(tasks[$1].status), weight: "medium"}
          ) {justify: "between"},
          when(not tasks[$1].description.is-empty,
            text(tasks[$1].description) {color: "muted", size: "sm"}),
          row(
            text("Priority: " + priorityLabel(tasks[$1].priority)) {color: priorityColor(tasks[$1].priority), size: "sm"},
            when(not tasks[$1].assignee.is-empty,
              text("@" + tasks[$1].assignee) {color: "muted", size: "sm"}),
            text(dueStatusLabel(dueDateStatus(tasks[$1].dueDate))) {color: dueStatusColor(dueDateStatus(tasks[$1].dueDate)), size: "sm"}
          ) {gap: "md"},
          when(not tasks[$1].tags.is-empty,
            row(
              for tag in tasks[$1].tags
                TaskTagPill(tag) {key: tag}
            ) {gap: "xs", wrap: true}),
          row(
            link(to="/projects/" + tasks[$1].projectId.show + "/tasks/" + $1.show) {text: "Open"},
            MoveTaskBtn {taskId: $1},
            DeleteTaskBtn {taskId: $1}
          ) {gap: "sm", justify: "end"}
        ) {gap: "xs"}
      ) {pad: "md"}

# ====== Tiles: Task List view ======

tile TaskListEmptyState
    = card(
        column(
          text("No tasks match the current filter.") {color: "muted"},
          text("Try clearing filters or creating a new task.") {color: "muted", size: "sm"})
        {gap: "xs"}) {pad: "md"}

tile ProjectTaskListView
    in=ProjectId
    = column(
        if filteredTasks(tasks, $1, filter).is-empty
          then TaskListEmptyState
          else column(
                 for tid in filteredTasks(tasks, $1, filter)
                   TaskCard(tid) {key: tid.show}
               ) {gap: "sm"}
      ) {gap: "md"}

# ====== Tiles: Board view ======

tile BoardColumnTask
    in=TaskId
    = card(
        column(
          link(to="/projects/" + tasks[$1].projectId.show + "/tasks/" + $1.show) {
            text: tasks[$1].title, weight: "bold"
          },
          row(
            text(priorityLabel(tasks[$1].priority)) {color: priorityColor(tasks[$1].priority), size: "sm"},
            when(not tasks[$1].assignee.is-empty,
              text("@" + tasks[$1].assignee) {color: "muted", size: "sm"})
          ) {gap: "sm"},
          when(not tasks[$1].tags.is-empty,
            row(
              for tag in tasks[$1].tags
                TaskTagPill(tag) {key: tag}
            ) {gap: "xs", wrap: true}),
          row(
            MoveTaskBtn {taskId: $1},
            DeleteTaskBtn {taskId: $1}
          ) {gap: "xs", justify: "end"}
        ) {gap: "xs"}
      ) {pad: "sm", bg: "bg", radius: "sm"}

tile BoardColumnBacklog
    in=ProjectId
    = panel(
        column(
          heading(statusLabel(Backlog)) {size: "md", color: statusColor(Backlog)},
          text(tasksByStatus(tasks, $1, filter, Backlog).length.show + " tasks") {color: "muted", size: "sm"},
          column(
            for tid in tasksByStatus(tasks, $1, filter, Backlog)
              BoardColumnTask(tid) {key: tid.show}
          ) {gap: "xs"})
        {gap: "sm"}
      ) {pad: "sm", bg: "surface", radius: "md"}

tile BoardColumnInProgress
    in=ProjectId
    = panel(
        column(
          heading(statusLabel(InProgress)) {size: "md", color: statusColor(InProgress)},
          text(tasksByStatus(tasks, $1, filter, InProgress).length.show + " tasks") {color: "muted", size: "sm"},
          column(
            for tid in tasksByStatus(tasks, $1, filter, InProgress)
              BoardColumnTask(tid) {key: tid.show}
          ) {gap: "xs"})
        {gap: "sm"}
      ) {pad: "sm", bg: "surface", radius: "md"}

tile BoardColumnReview
    in=ProjectId
    = panel(
        column(
          heading(statusLabel(Review)) {size: "md", color: statusColor(Review)},
          text(tasksByStatus(tasks, $1, filter, Review).length.show + " tasks") {color: "muted", size: "sm"},
          column(
            for tid in tasksByStatus(tasks, $1, filter, Review)
              BoardColumnTask(tid) {key: tid.show}
          ) {gap: "xs"})
        {gap: "sm"}
      ) {pad: "sm", bg: "surface", radius: "md"}

tile BoardColumnDone
    in=ProjectId
    = panel(
        column(
          heading(statusLabel(Done)) {size: "md", color: statusColor(Done)},
          text(tasksByStatus(tasks, $1, filter, Done).length.show + " tasks") {color: "muted", size: "sm"},
          column(
            for tid in tasksByStatus(tasks, $1, filter, Done)
              BoardColumnTask(tid) {key: tid.show}
          ) {gap: "xs"})
        {gap: "sm"}
      ) {pad: "sm", bg: "surface", radius: "md"}

tile ProjectBoardView
    in=ProjectId
    = grid(
        BoardColumnBacklog($1),
        BoardColumnInProgress($1),
        BoardColumnReview($1),
        BoardColumnDone($1)
      ) {cols: {base: 1, md: 2, lg: 4}, gap: "md"}

# ====== Tiles: Project page (list/board switching) ======

tile ProjectPageHeader
    in=Project
    = row(
        column(
          link(to="/") {text: "< Back to projects", color: "muted", size: "sm"},
          heading($1.name) {size: "xl"},
          text($1.description) {color: "muted"}
        ) {gap: "xs"},
        row(
          link(to="/projects/" + $1.id.show + "/new-task") {text: "+ New task"},
          ViewModeToggleBtn
        ) {gap: "sm", align: "center"}
      ) {justify: "between", align: "center"}

tile ProjectContent
    in=Project
    = column(
        ProjectPageHeader($1),
        FilterBar,
        if viewMode == ListView
          then ProjectTaskListView($1.id)
          else ProjectBoardView($1.id)
      ) {gap: "md"}

tile ProjectNotFound
    = column(
        heading("Project not found"),
        link(to="/") {text: "Back to projects"})
      {gap: "sm"}

tile ProjectPage
    = page(
        TopNav,
        column(
          match currentProject(route, projects) with
            | None    -> ProjectNotFound
            | Some(p) -> ProjectContent(p)
        ) {pad: "lg", gap: "md", max-w: 1200}
      )

# ====== Tiles: NewTaskPage ======

tile NewTaskTitleInput       = input(bind=draftTask.title, placeholder="Task title", id="task-title", required=true)
tile NewTaskDescriptionInput = textarea(bind=draftTask.description, placeholder="Description", rows=4, id="task-desc")
tile NewTaskPrioritySelect   = select(bind=draftTask.priority, options=priorityOptions(), placeholder="Priority")
tile NewTaskAssigneeInput    = input(bind=draftTask.assignee, placeholder="Assignee", id="task-assignee")
tile NewTaskTagsInput        = input(bind=draftTask.tags, placeholder="Comma-separated tags", id="task-tags")
tile NewTaskDueDateInput     = input(bind=draftTask.dueDate, type="date", id="task-due")

tile NewTaskForm
    = form(
        column(
          label(text="Title") {for: "task-title"},
          NewTaskTitleInput,
          label(text="Description") {for: "task-desc"},
          NewTaskDescriptionInput,
          label(text="Priority") {for: "task-priority"},
          NewTaskPrioritySelect,
          label(text="Assignee") {for: "task-assignee"},
          NewTaskAssigneeInput,
          label(text="Tags") {for: "task-tags"},
          NewTaskTagsInput,
          label(text="Due date") {for: "task-due"},
          NewTaskDueDateInput,
          row(
            button(text="Create task", type="submit") {bg: "primary"},
            link(to="/projects/" + route.params.get-or("id", "")) {text: "Cancel"}
          ) {gap: "sm"}
        ) {gap: "sm"}
      ) {pad: "md", bg: "surface", radius: "md"}

tile NewTaskPage
    = page(
        TopNav,
        column(
          match currentProject(route, projects) with
            | None    -> ProjectNotFound
            | Some(p) -> column(
                          link(to="/projects/" + p.id.show) {text: "< Back to " + p.name, color: "muted", size: "sm"},
                          heading("New task in " + p.name) {size: "xl"},
                          NewTaskForm
                        ) {gap: "md"}
        ) {pad: "lg", gap: "md", max-w: 720}
      )

# ====== Tiles: Task Detail Page ======

tile TaskTitleInput       = input(value=routeTitleValue(route, tasks), id="t-title", placeholder="Title")
tile TaskDescriptionInput = textarea(value=routeDescriptionValue(route, tasks), id="t-desc", rows=6, placeholder="Description")
tile TaskAssigneeInput    = input(value=routeAssigneeValue(route, tasks), id="t-assignee", placeholder="Assignee")
tile TaskStatusSelect     = select(value=routeStatusValue(route, tasks), options=statusOptions(), placeholder="Status")
tile TaskPrioritySelect   = select(value=routePriorityValue(route, tasks), options=priorityOptions(), placeholder="Priority")
tile TaskDueDateInput     = input(value=routeDueDateValue(route, tasks), type="date", id="t-due")

fn routeTitleValue(r: Route, ts: Map(TaskId, Task)) -> Text
   = match routeTaskId(r) with
       | None      -> ""
       | Some(tid) -> match ts.get(tid) with
                        | None    -> ""
                        | Some(t) -> t.title

fn routeDescriptionValue(r: Route, ts: Map(TaskId, Task)) -> Text
   = match routeTaskId(r) with
       | None      -> ""
       | Some(tid) -> match ts.get(tid) with
                        | None    -> ""
                        | Some(t) -> t.description

fn routeAssigneeValue(r: Route, ts: Map(TaskId, Task)) -> Text
   = match routeTaskId(r) with
       | None      -> ""
       | Some(tid) -> match ts.get(tid) with
                        | None    -> ""
                        | Some(t) -> t.assignee

fn routeStatusValue(r: Route, ts: Map(TaskId, Task)) -> Status
   = match routeTaskId(r) with
       | None      -> Backlog
       | Some(tid) -> match ts.get(tid) with
                        | None    -> Backlog
                        | Some(t) -> t.status

fn routePriorityValue(r: Route, ts: Map(TaskId, Task)) -> Priority
   = match routeTaskId(r) with
       | None      -> Med
       | Some(tid) -> match ts.get(tid) with
                        | None    -> Med
                        | Some(t) -> t.priority

fn routeDueDateValue(r: Route, ts: Map(TaskId, Task)) -> Text
   = match routeTaskId(r) with
       | None      -> ""
       | Some(tid) -> match ts.get(tid) with
                        | None    -> ""
                        | Some(t) -> match t.dueDate with
                                       | None    -> ""
                                       | Some(d) -> formatDate(d)

tile TaskTagsList
    in=TaskId
    = row(
        for tag in tasks[$1].tags
          row(
            text("#" + tag) {color: "primary", size: "sm"},
            RemoveTagBtn {tagName: tag, key: tag}
          ) {gap: "xs", key: tag}
      ) {gap: "sm", wrap: true}

tile TagDraftInput = input(bind=tagDraft, placeholder="Add tag", id="tag-draft")

tile AddTagForm
    = form(
        row(
          TagDraftInput,
          button(text="Add", type="submit") {variant: "ghost"}
        ) {gap: "xs"}
      )

tile SubtaskRow
    in=TaskId
    = card(
        row(
          link(to="/projects/" + tasks[$1].projectId.show + "/tasks/" + $1.show) {
            text: tasks[$1].title
          },
          text(statusLabel(tasks[$1].status)) {color: statusColor(tasks[$1].status), size: "sm"},
          DeleteTaskBtn {taskId: $1}
        ) {gap: "sm", justify: "between", align: "center"}
      ) {pad: "sm", bg: "surface"}

tile SubtasksSection
    in=TaskId
    = column(
        heading("Subtasks") {size: "md"},
        if subtasksFor(tasks, $1).is-empty
          then text("No subtasks") {color: "muted", size: "sm"}
          else column(
                 for stid in subtasksFor(tasks, $1)
                   SubtaskRow(stid) {key: stid.show}
               ) {gap: "xs"}
      ) {gap: "sm"}

tile CommentItem
    in=CommentId
    = card(
        column(
          row(
            text(comments[$1].author) {weight: "bold", size: "sm"},
            text(formatDateTime(comments[$1].createdAt)) {color: "muted", size: "sm"},
            DeleteCommentBtn {commentId: $1}
          ) {justify: "between", align: "center"},
          text(comments[$1].body))
        {gap: "xs"}
      ) {pad: "sm", bg: "surface"}

tile CommentDraftInput = textarea(bind=commentDraft, placeholder="Write a comment...", rows=3, id="comment-draft")

tile AddCommentForm
    = form(
        column(
          CommentDraftInput,
          button(text="Post comment", type="submit") {bg: "primary"}
        ) {gap: "sm"}
      )

tile CommentsSection
    in=TaskId
    = column(
        heading("Comments") {size: "md"},
        if commentsForTask(comments, $1).is-empty
          then text("No comments yet") {color: "muted", size: "sm"}
          else column(
                 for cid in commentsForTask(comments, $1)
                   CommentItem(cid) {key: cid.show}
               ) {gap: "xs"},
        AddCommentForm
      ) {gap: "sm"}

tile TaskMetadataSection
    in=Task
    = card(
        column(
          row(
            column(
              label(text="Status") {for: "t-status"},
              TaskStatusSelect
            ) {gap: "xs"},
            column(
              label(text="Priority") {for: "t-priority"},
              TaskPrioritySelect
            ) {gap: "xs"}
          ) {gap: "md"},
          row(
            column(
              label(text="Assignee") {for: "t-assignee"},
              TaskAssigneeInput
            ) {gap: "xs"},
            column(
              label(text="Due date") {for: "t-due"},
              TaskDueDateInput
            ) {gap: "xs"}
          ) {gap: "md"},
          column(
            text("Tags") {size: "sm", weight: "bold"},
            TaskTagsList($1.id),
            AddTagForm
          ) {gap: "xs"},
          row(
            text("Created: " + formatDateTime($1.createdAt)) {color: "muted", size: "sm"},
            text("Updated: " + formatDateTime($1.updatedAt)) {color: "muted", size: "sm"}
          ) {gap: "md"}
        ) {gap: "md"}
      ) {pad: "md"}

tile TaskDetailContent
    in=Task
    = column(
        row(
          link(to="/projects/" + $1.projectId.show) {text: "< Back", color: "muted"},
          DeleteTaskBtn {taskId: $1.id}
        ) {justify: "between"},
        column(
          label(text="Title") {for: "t-title"},
          TaskTitleInput,
          label(text="Description") {for: "t-desc"},
          TaskDescriptionInput
        ) {gap: "xs"},
        TaskMetadataSection($1),
        SubtasksSection($1.id),
        CommentsSection($1.id)
      ) {gap: "md"}

tile TaskNotFound
    = column(
        heading("Task not found"),
        link(to="/") {text: "Back to projects"})
      {gap: "sm"}

fn currentTask(r: Route, ts: Map(TaskId, Task)) -> Option(Task)
   = match routeTaskId(r) with
       | None      -> None
       | Some(tid) -> ts.get(tid)

tile TaskDetailPage
    = page(
        TopNav,
        column(
          match currentTask(route, tasks) with
            | None    -> TaskNotFound
            | Some(t) -> TaskDetailContent(t)
        ) {pad: "lg", gap: "md", max-w: 900}
      )

# ====== Tiles: Settings Page ======

tile SettingsPage
    = page(
        TopNav,
        column(
          heading("Settings") {size: "xxl"},
          card(
            column(
              heading("Theme") {size: "lg"},
              text("Current: " + themeName) {color: "muted"},
              ThemeToggleBtn
            ) {gap: "sm"}
          ) {pad: "md"},
          card(
            column(
              heading("Data") {size: "lg"},
              text(projects.size.show + " projects") {color: "muted"},
              text(tasks.size.show + " tasks") {color: "muted"},
              text(comments.size.show + " comments") {color: "muted"}
            ) {gap: "xs"}
          ) {pad: "md"}
        ) {pad: "lg", gap: "md", max-w: 720}
      )

# ====== Tiles: NotFound ======

tile NotFound
    = page(
        TopNav,
        column(
          heading("404") {size: "xxl"},
          text("Page not found") {color: "muted"},
          link(to="/") {text: "Back to projects"}
        ) {pad: "lg", gap: "md", align: "center"}
      )

# ====== Themes ======

theme Light = {
    colors: {
        bg: "#ffffff",
        fg: "#1a1a1a",
        muted: "#666666",
        primary: "#0070f3",
        success: "#0a7c2f",
        warning: "#b07c00",
        danger: "#c4222a",
        surface: "#f7f7f7",
        border: "#e0e0e0"
    },
    spacing: {xs: "4px", sm: "8px", md: "16px", lg: "24px", xl: "40px", xxl: "64px"},
    radius: {none: "0", sm: "4px", md: "8px", lg: "16px", pill: "999px"},
    typography: {
        family: "system-ui, sans-serif",
        size: {xs: "12px", sm: "14px", md: "16px", lg: "20px", xl: "28px", xxl: "40px"},
        weight: {normal: "400", medium: "500", bold: "700"},
        line-height: "1.5"
    },
    shadow: {none: "none", sm: "0 1px 2px rgba(0,0,0,0.1)", md: "0 4px 8px rgba(0,0,0,0.1)", lg: "0 8px 24px rgba(0,0,0,0.15)"},
    breakpoints: {sm: "640px", md: "768px", lg: "1024px", xl: "1280px"}
}

theme Dark = {
    colors: {
        bg: "#0f0f10",
        fg: "#f5f5f5",
        muted: "#9a9a9a",
        primary: "#3b9bff",
        success: "#3fbf64",
        warning: "#e0a83a",
        danger: "#ef5350",
        surface: "#1a1a1c",
        border: "#2a2a2d"
    },
    spacing: {xs: "4px", sm: "8px", md: "16px", lg: "24px", xl: "40px", xxl: "64px"},
    radius: {none: "0", sm: "4px", md: "8px", lg: "16px", pill: "999px"},
    typography: {
        family: "system-ui, sans-serif",
        size: {xs: "12px", sm: "14px", md: "16px", lg: "20px", xl: "28px", xxl: "40px"},
        weight: {normal: "400", medium: "500", bold: "700"},
        line-height: "1.5"
    },
    shadow: {none: "none", sm: "0 1px 2px rgba(0,0,0,0.4)", md: "0 4px 8px rgba(0,0,0,0.45)", lg: "0 8px 24px rgba(0,0,0,0.5)"},
    breakpoints: {sm: "640px", md: "768px", lg: "1024px", xl: "1280px"}
}

# ====== App ======

app ProjectManagement
    caps   = [storage.read, storage.write, nav.push, nav.replace, notification.show]
    routes = {
        "/"                              -> ProjectsPage,
        "/projects/:id"                  -> ProjectPage,
        "/projects/:id/new-task"         -> NewTaskPage,
        "/projects/:id/tasks/:taskId"    -> TaskDetailPage,
        "/settings"                      -> SettingsPage,
        "/404"                           -> NotFound
    }
    init   = []
    theme  = themeName
    meta   = {
        title: "Strand PM",
        description: "Project management tool built with Strand"
    }
