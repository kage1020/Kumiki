{
  "name": "@kumikijs/compiler",
  "version": "0.4.0",
  "type": "module",
  "description": "Kumiki compiler — lexer, parser, typechecker, and code generator.",
  "license": "Apache-2.0",
  "author": "kage1020",
  "homepage": "https://github.com/kage1020/Kumiki/tree/main/packages/compiler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kage1020/Kumiki.git",
    "directory": "packages/compiler"
  },
  "bugs": "https://github.com/kage1020/Kumiki/issues",
  "keywords": [
    "kumiki",
    "ai-first",
    "compiler",
    "dsl",
    "codegen",
    "language"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./src/node.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./node": {
        "types": "./dist/node.d.ts",
        "import": "./dist/node.js"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "biome check src test"
  },
  "dependencies": {
    "@kumikijs/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
