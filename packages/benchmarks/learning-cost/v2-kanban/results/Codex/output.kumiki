type CardId = nominal Text where uuid
type Column = Todo | Doing | Done
type Card = {id: CardId, title: Text, column: Column, createdAt: Time}

slot cards : Map(CardId, Card) = {}
slot draft : Text = ""
slot ready : Bool = false

effect saveCards cap=storage.write
                 in=Map(CardId, Card)
                 out=Result(Unit, Text)
                 policy=debounce(300ms)
                 map-request={key: "kanban-cards", value: $1}

effect loadCards cap=storage.read
                 in=Unit
                 out=Result(Option(Map(CardId, Card)), Text)
                 policy=once
                 map-request={key: "kanban-cards", decode: Decoder.Json(Map(CardId, Card))}

fn columnLabel(c: Column) -> Text
   = match c with
       | Todo -> "Todo"
       | Doing -> "Doing"
       | Done -> "Done"

fn prevColumn(c: Column) -> Column
   = match c with
       | Todo -> Todo
       | Doing -> Todo
       | Done -> Doing

fn nextColumn(c: Column) -> Column
   = match c with
       | Todo -> Doing
       | Doing -> Done
       | Done -> Done

fn columnCount(cs: Map(CardId, Card), c: Column) -> Int
   = cs.filter($2.column == c).size

fn cardsInColumn(cs: Map(CardId, Card), c: Column) -> List(CardId)
   = cs.entries.filter($2.column == c).sort-by($2.createdAt).map($1)

fn canMoveLeft(c: Column) -> Bool
   = c != Todo

fn canMoveRight(c: Column) -> Bool
   = c != Done

theme BoardTheme = {
    colors: {
        bg: "#f6f8fb",
        fg: "#172033",
        muted: "#667085",
        primary: "#2563eb",
        success: "#15803d",
        warning: "#b45309",
        danger: "#dc2626",
        surface: "#ffffff",
        border: "#d7dce5"
    },
    spacing: {
        xs: "4px",
        sm: "8px",
        md: "16px",
        lg: "24px",
        xl: "40px",
        xxl: "64px"
    },
    radius: {
        none: "0",
        sm: "4px",
        md: "8px",
        lg: "12px",
        pill: "999px"
    },
    typography: {
        family: "system-ui, sans-serif",
        size: {
            xs: "12px",
            sm: "14px",
            md: "16px",
            lg: "20px",
            xl: "28px",
            xxl: "40px"
        },
        weight: {
            normal: "400",
            medium: "500",
            bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm: "0 1px 2px rgba(15,23,42,0.08)",
        md: "0 8px 24px rgba(15,23,42,0.10)",
        lg: "0 16px 40px rgba(15,23,42,0.14)"
    },
    breakpoints: {
        sm: "640px",
        md: "768px",
        lg: "1024px",
        xl: "1280px"
    }
}

reducer loadAll
    on=app.start
    do= emit loadCards()

reducer cardsLoaded
    on=loadCards.ok($loaded, _)
    do= cards := $loaded.get-or({})
        ready := true

reducer cardsLoadFailed
    on=loadCards.err($error, _)
    do= ready := true

reducer saveCardsOk
    on=saveCards.ok($unit, _)
    do= let ignored = $unit

reducer saveCardsErr
    on=saveCards.err($error, _)
    do= let ignored = $error

reducer addCard
    on=ui.submit(NewCardForm)
    do= if draft.trim.is-empty
        then ()
        else {
          let id = CardId.fresh()
          cards[id] := {id: id, title: draft.trim, column: Todo, createdAt: now}
          draft := ""
          emit saveCards(cards)
        }

reducer moveLeft
    on=ui.click(MoveLeftButton)
    do= cards[$el.cardId].column := prevColumn(cards[$el.cardId].column)
        emit saveCards(cards)

reducer moveRight
    on=ui.click(MoveRightButton)
    do= cards[$el.cardId].column := nextColumn(cards[$el.cardId].column)
        emit saveCards(cards)

reducer deleteCard
    on=ui.click(DeleteButton)
    do= cards := cards.remove($el.cardId)
        emit saveCards(cards)

tile AddButton = button(text="Add", type="submit", disabled=draft.trim.is-empty) {bg: "primary", color: "bg"}

tile MoveLeftButton in=CardId
    = button(text="<", onClick=moveLeft, disabled=!canMoveLeft(cards[$1].column)) {cardId: $1, aria-label: "Move left"}

tile MoveRightButton in=CardId
    = button(text=">", onClick=moveRight, disabled=!canMoveRight(cards[$1].column)) {cardId: $1, aria-label: "Move right"}

tile DeleteButton in=CardId
    = button(text="x", onClick=deleteCard, variant="ghost") {cardId: $1, aria-label: "Delete card"}

tile NewCardForm
    = form(
        row(
          input(bind=draft, placeholder="New card title", auto-focus=true),
          AddButton
        ) {gap: "sm", align: "center"}
      ) {novalidate: true}

tile CardTile in=CardId
    = card(
        column(
          text(cards[$1].title) {weight: "medium"},
          row(
            MoveLeftButton($1),
            MoveRightButton($1),
            DeleteButton($1)
          ) {gap: "xs", justify: "end"}
        ) {gap: "sm"}
      ) {pad: "md", bg: "surface", radius: "md", shadow: "sm", key: $1.show}

tile EmptyColumn = box(
    text("No cards") {color: "muted", size: "sm"}
  ) {pad: "md", bg: "bg", radius: "md"}

tile KanbanColumn in=Column
    = panel(
        column(
          row(
            heading(columnLabel($1) + " (" + columnCount(cards, $1).show + ")") {level: 2, size: "lg"},
            text("")
          ) {justify: "between", align: "center"},
          if cardsInColumn(cards, $1).is-empty
          then EmptyColumn
          else column(
            for id in cardsInColumn(cards, $1)
              CardTile(id)
          ) {gap: "sm"}
        ) {gap: "md"}
      ) {pad: "md", bg: "surface", radius: "lg", shadow: "sm"}

tile Board
    = grid(
        KanbanColumn(Todo),
        KanbanColumn(Doing),
        KanbanColumn(Done)
      ) {cols: {base: 1, md: 3}, gap: "md"}

tile App
    = page(
        column(
          row(
            column(
              heading("Kanban Board") {level: 1, size: "xl"},
              text("Add cards, move them across columns, and keep progress saved locally.") {color: "muted"}
            ) {gap: "xs"},
            text(if ready then "Saved board" else "Loading...") {color: "muted", size: "sm"}
          ) {justify: "between", align: "center"},
          NewCardForm,
          Board
        ) {gap: "lg"}
      ) {title: "Kanban Board", pad: "lg", bg: "bg"}

tile NotFound
    = page(
        column(
          heading("404") {level: 1},
          text("Page not found"),
          link(to="/") {text: "Back to board"}
        ) {gap: "md"}
      ) {title: "Not Found", pad: "lg"}

app KanbanApp
    caps   = [storage.read, storage.write]
    routes = {"/" -> App, "/404" -> NotFound}
    init   = []
    theme  = BoardTheme
