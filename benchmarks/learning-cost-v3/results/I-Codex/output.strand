        column(
          fieldset(
            column(
              label(text="Title") {for: "new-title"},
              DraftTitleInput,
              error(field=draft.title)
            ) {gap: "xs"}
          ) {legend: "Title"},
          fieldset(
            column(
              label(text="Body") {for: "new-body"},
              DraftBodyInput
            ) {gap: "xs"}
          ) {legend: "Description"},
          grid(
            fieldset(
              column(
                label(text="Priority") {for: "new-priority"},
