# Feature: List — literal, .map / .filter, and `for ... in` rendering.

slot nums : List(Int) = [1, 2, 3, 4, 5]

fn doubled(xs: List(Int)) -> List(Int) = xs.map($1 * 2)
fn evens(xs: List(Int))   -> List(Int) = xs.filter($1 % 2 == 0)

reducer push on=ui.click(PushBtn) do= nums := nums.push(nums.size + 1)

tile PushBtn = button(text="append", onClick=push)
tile App = column(
             text("all:     " + nums.show),
             text("doubled: " + doubled(nums).show),
             text("evens:   " + evens(nums).show),
             column(for n in nums text("• " + n.show) {key: n.show}),
             PushBtn)

app ListFeature
    caps   = []
    routes = {"/" -> App, "/404" -> App}
    init   = []
