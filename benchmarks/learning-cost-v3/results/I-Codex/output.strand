          row(
            button(text="Create issue", type="submit") {bg: "primary"},
            CancelCreateBtn
          ) {gap: "sm", align: "center"}
        ) {gap: "md"}
      )

tile NewIssuePage
    = page(
        AppNav,
        column(
          link(to="/") {text: "Back to issues"},
          heading("New issue") {level: 1, size: "xxl"},
          NewIssueForm
        ) {gap: "md"}
      ) {pad: "lg", gap: "lg", max-w: 840}

# ====== Settings tiles ======

tile LightThemeBtn
    = button(text="Light", onClick=useLightTheme) {
        variant: if themeName == "LightTheme" then "primary" else "ghost"
      }

tile DarkThemeBtn
    = button(text="Dark", onClick=useDarkTheme) {
        variant: if themeName == "DarkTheme" then "primary" else "ghost"
      }

tile ThemeToggleBtn
    = button(text="Toggle theme", onClick=toggleTheme) {variant: "secondary"}

tile SettingsPage
    = page(
        AppNav,
        column(
          heading("Settings") {level: 1, size: "xxl"},
          panel(
            column(
              heading("Theme") {level: 2, size: "lg"},
              text("Current theme: " + themeName) {color: "muted"},
              row(
                LightThemeBtn,
                DarkThemeBtn,
                ThemeToggleBtn
              ) {gap: "sm", align: "center", wrap: true}
            ) {gap: "md"}
          ) {pad: "md", bg: "surface"}
        ) {gap: "md"}
      ) {pad: "lg", gap: "lg", max-w: 720}

# ====== Not found ======

tile NotFound
    = page(
        AppNav,
        column(
          heading("404") {level: 1, size: "xxl"},
          text("Page not found") {color: "muted"},
          link(to="/") {text: "Back to issues"}
        ) {gap: "md"}
      ) {pad: "lg", gap: "lg", max-w: 720}

# ====== Themes ======

theme LightTheme = {
    colors: {
        bg: "#f6f8fa",
        fg: "#1f2328",
        muted: "#656d76",
        primary: "#0969da",
        success: "#1a7f37",
        warning: "#9a6700",
        danger: "#cf222e",
        surface: "#ffffff",
        border: "#d0d7de"
    },
    spacing: {
        xs: "4px",
        sm: "8px",
        md: "16px",
        lg: "24px",
        xl: "40px",
        xxl: "64px"
    },
    radius: {
        none: "0",
        sm: "4px",
        md: "8px",
        lg: "12px",
        pill: "999px"
    },
    typography: {
        family: "system-ui, sans-serif",
        size: {
            xs: "12px",
            sm: "14px",
            md: "16px",
            lg: "20px",
            xl: "28px",
            xxl: "36px"
        },
        weight: {
            normal: "400",
            medium: "500",
            bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm: "0 1px 2px rgba(31,35,40,0.08)",
        md: "0 8px 24px rgba(31,35,40,0.12)"
    },
    breakpoints: {
        sm: "640px",
        md: "768px",
        lg: "1024px",
        xl: "1280px"
    }
}

