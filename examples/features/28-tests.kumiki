# Feature: in-language `test` definitions (run with `kumiki test`).
# A reducer-test checks a reducer's pure output; a tile-test checks rendered
# structure. Tests are excluded from the production build.

slot count : Int = 0

reducer inc on=ui.click(IncBtn) do= count := count + 1
reducer dec on=ui.click(DecBtn) do= count := count - 1

tile IncBtn = button(text="+1", onClick=inc)
tile DecBtn = button(text="-1", onClick=dec)
tile Greeting in=Text = heading("Hi, " + $1)
tile App = column(heading("Count: " + count.show), row(DecBtn, IncBtn)) {pad: "lg", gap: "md"}

app TestsFeature
    caps   = []
    routes = {"/" -> App, "/404" -> App}
    init   = []

test inc-increments =
    reducer-test inc
        given  = {slots: {count: 0}, event: {type: ui.click, target: IncBtn}}
        expect = {slots: {count: 1}, effects: []}

test dec-decrements =
    reducer-test dec
        given  = {slots: {count: 5}, event: {type: ui.click, target: DecBtn}}
        expect = {slots: {count: 4}, effects: []}

test app-renders-count =
    tile-test App
        given  = {slots: {count: 5}}
        expect = column(heading("Count: 5"), row(button(text="-1"), button(text="+1")))

test greeting-renders-input =
    tile-test Greeting
        given  = {slots: {}, in: "Ada"}
        expect = heading("Hi, Ada")
