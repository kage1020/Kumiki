{
  "name": "@kumiki/compiler",
  "version": "0.1.0",
  "type": "module",
  "description": "Kumiki compiler — lexer, parser, typechecker, and code generator.",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./src/node.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "biome check src test"
  },
  "dependencies": {
    "@kumiki/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
