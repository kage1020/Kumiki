# Feature: the idioms behind the three spec clarifications in issue #62 —
# (1) branch on a value with if/else or a *union* match, never literal patterns;
# (2) a tile reads its positional argument as `$1` only when it declares `in=`;
# (3) a label is the `text=` argument (canonical, same as `button`).

type Urgency = Overdue | Today | Later

slot urgency : Urgency   = Today
slot items   : List(Text) = ["alpha", "beta", "gamma"]

# ✅ match on a UNION variant (not a Text literal)
fn tone(u: Urgency) -> Text = match u with
                                | Overdue -> "red"
                                | Today   -> "amber"
                                | Later   -> "gray"

# ✅ a tile with `in=` reads its argument as `$1`
tile Item in=Text = text($1)

tile App = column(
             # ✅ branch on a value with if/else, not a literal match
             heading(if tone(urgency) == "red" then "Urgent" else "Scheduled"),
             text(tone(urgency)),
             for x in items Item(x),
             # ✅ link label via the text= argument
             link(to="/", text="Home")) {pad: "lg", gap: "md"}

app MatchAndArgs
    caps   = []
    routes = {"/" -> App, "/404" -> App}
    init   = []
