type ProjectId = nominal Text where uuid
type TaskId = nominal Text where uuid
type CommentId = nominal Text where uuid
type Status = Backlog | InProgress | Review | Done
type Priority = Low | Med | High | Critical
type ViewMode = ListView | BoardView

type Project = {id: ProjectId, name: Text, description: Text, color: Text, archived: Bool, createdAt: Time}
type Task = {id: TaskId, projectId: ProjectId, title: Text, description: Text, status: Status, priority: Priority, assignee: Text, dueDate: Option(Time), tags: List(Text), parentTaskId: Option(TaskId), createdAt: Time, updatedAt: Time}
type Comment = {id: CommentId, taskId: TaskId, author: Text, body: Text, createdAt: Time}
type FilterState = {status: Option(Status), priority: Option(Priority), assignee: Text, search: Text}

slot projects : Map(ProjectId, Project) = {}
slot tasks : Map(TaskId, Task) = {}
slot comments : Map(CommentId, Comment) = {}
slot viewMode : ViewMode = ListView
slot filter : FilterState = {status: None, priority: None, assignee: "", search: ""}
slot themeName : Text = "Light"
slot draftProject : {name: Text, description: Text, color: Text} = {name: "", description: "", color: "#000000"}
slot draftTask : {title: Text, description: Text, priority: Priority, assignee: Text, tags: Text, dueDate: Text} = {title: "", description: "", priority: Med, assignee: "", tags: "", dueDate: ""}
slot commentDraft : Text = ""
slot ready : Bool = false

slot loadedProjects : Bool = false
slot loadedTasks : Bool = false
slot loadedComments : Bool = false
slot taskTagDraft : Text = ""

effect saveProjects cap=storage.write in=Map(ProjectId, Project) out=Result(Unit, Text) policy=debounce(300ms) map-request={key: "projects", value: $1}
effect saveTasks cap=storage.write in=Map(TaskId, Task) out=Result(Unit, Text) policy=debounce(300ms) map-request={key: "tasks", value: $1}
effect saveComments cap=storage.write in=Map(CommentId, Comment) out=Result(Unit, Text) policy=debounce(300ms) map-request={key: "comments", value: $1}
effect loadProjects cap=storage.read in=Unit out=Result(Option(Map(ProjectId, Project)), Text) policy=once map-request={key: "projects", decode: Decoder.Json(Map(ProjectId, Project))}
effect loadTasks cap=storage.read in=Unit out=Result(Option(Map(TaskId, Task)), Text) policy=once map-request={key: "tasks", decode: Decoder.Json(Map(TaskId, Task))}
effect loadComments cap=storage.read in=Unit out=Result(Option(Map(CommentId, Comment)), Text) policy=once map-request={key: "comments", decode: Decoder.Json(Map(CommentId, Comment))}

fn tasksForProject(ts: Map(TaskId, Task), pid: ProjectId) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == pid)
       .sort-by($2.updatedAt)
       .reverse
       .map($1)

fn subtasksFor(ts: Map(TaskId, Task), parentId: TaskId) -> List(TaskId)
   = ts.entries
       .filter($2.parentTaskId == Some(parentId))
       .map($1)

fn filteredTasks(ts: Map(TaskId, Task), pid: ProjectId, f: FilterState) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == pid)
       .filter(match f.status with | Some(s) -> $2.status == s | None -> true)
       .filter(match f.priority with | Some(p) -> $2.priority == p | None -> true)
       .filter(if f.assignee.is-empty then true else $2.assignee.contains(f.assignee))
       .filter(if f.search.is-empty then true else $2.title.contains(f.search) || $2.description.contains(f.search))
       .sort-by($2.updatedAt)
       .reverse
       .map($1)

fn tasksByStatus(ts: Map(TaskId, Task), pid: ProjectId, f: FilterState, s: Status) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == pid)
       .filter($2.status == s)
       .filter(match f.priority with | Some(p) -> $2.priority == p | None -> true)
       .filter(if f.assignee.is-empty then true else $2.assignee.contains(f.assignee))
       .filter(if f.search.is-empty then true else $2.title.contains(f.search) || $2.description.contains(f.search))
       .sort-by($2.updatedAt)
       .reverse
       .map($1)

fn commentsForTask(cs: Map(CommentId, Comment), tid: TaskId) -> List(CommentId)
   = cs.entries
       .filter($2.taskId == tid)
       .sort-by($2.createdAt)
       .map($1)

fn statusLabel(s: Status) -> Text = match s with | Backlog -> "Backlog" | InProgress -> "In Progress" | Review -> "Review" | Done -> "Done"
fn statusColor(s: Status) -> Text = match s with | Backlog -> "muted" | InProgress -> "primary" | Review -> "warning" | Done -> "success"
fn priorityLabel(p: Priority) -> Text = match p with | Low -> "Low" | Med -> "Medium" | High -> "High" | Critical -> "Critical"
fn priorityColor(p: Priority) -> Text = match p with | Low -> "muted" | Med -> "primary" | High -> "warning" | Critical -> "danger"

fn formatDate(t: Time) -> Text = t.format("yyyy-MM-dd")

fn dueDateStatus(due: Option(Time)) -> Text
   = match due with
       | None -> "No Due"
       | Some(d) ->
           if d < now then "Overdue"
           else if d < now.plus(Duration.s(86400)) then "Today"
           else if d < now.plus(Duration.s(259200)) then "Soon"
           else "Upcoming"

fn parseTags(text: Text) -> List(Text)
   = text.split(",").map($1.trim).filter(not $1.is-empty)

fn routeProjectId(r: Route) -> Option(ProjectId)
   = ProjectId.parse(r.params.get-or("id", ""))

fn routeTaskId(r: Route) -> Option(TaskId)
   = TaskId.parse(r.params.get-or("taskId", ""))

fn currentProject(r: Route, ps: Map(ProjectId, Project)) -> Option(Project)
   = match routeProjectId(r) with | Some(id) -> ps.get(id) | None -> None

fn nextStatus(s: Status) -> Status = match s with | Backlog -> InProgress | InProgress -> Review | Review -> Done | Done -> Done

reducer loadAll
    on=app.start
    do= emit loadProjects()
        emit loadTasks()
        emit loadComments()

reducer onProjectsLoaded
    on=loadProjects.ok($m, _)
    do= projects := $m.get-or({})
        loadedProjects := true
        ready := loadedProjects && loadedTasks && loadedComments

reducer onTasksLoaded
    on=loadTasks.ok($m, _)
    do= tasks := $m.get-or({})
        loadedTasks := true
        ready := loadedProjects && loadedTasks && loadedComments

reducer onCommentsLoaded
    on=loadComments.ok($m, _)
    do= comments := $m.get-or({})
        loadedComments := true
        ready := loadedProjects && loadedTasks && loadedComments

reducer onProjectsErr on=loadProjects.err($_, _) do= loadedProjects := true; ready := loadedProjects && loadedTasks && loadedComments
reducer onTasksErr on=loadTasks.err($_, _) do= loadedTasks := true; ready := loadedProjects && loadedTasks && loadedComments
reducer onCommentsErr on=loadComments.err($_, _) do= loadedComments := true; ready := loadedProjects && loadedTasks && loadedComments

reducer toggleTheme
    on=ui.click(ThemeBtn)
    do= themeName := if themeName == "Light" then "Dark" else "Light"

reducer createProject
    on=ui.submit(NewProjectForm)
    do= let id = ProjectId.fresh()
        projects[id] := {id: id, name: draftProject.name, description: draftProject.description, color: draftProject.color, archived: false, createdAt: now}
        draftProject := {name: "", description: "", color: "#000000"}
        emit saveProjects(projects)
        emit navigate({path: "/projects/" + id.show, params: {}})

reducer archiveProject
    on=ui.click(ArchiveProjectBtn)
    do= projects[$el.projectId].archived := true
        emit saveProjects(projects)

reducer unarchiveProject
    on=ui.click(UnarchiveProjectBtn)
    do= projects[$el.projectId].archived := false
        emit saveProjects(projects)

reducer deleteProject
    on=ui.click(DeleteProjectBtn)
    do= let pid = $el.projectId
        projects := projects.remove(pid)
        let tids = tasksForProject(tasks, pid)
        for tid in tids {
            let cids = commentsForTask(comments, tid)
            for cid in cids {
                comments := comments.remove(cid)
            }
        }
        for tid in tids {
            tasks := tasks.remove(tid)
        }
        emit saveProjects(projects)
        emit saveTasks(tasks)
        emit saveComments(comments)
        emit navigate({path: "/", params: {}})

reducer createTask
    on=ui.submit(NewTaskForm)
    do= match routeProjectId($route) with
          | Some(pid) -> {
                let id = TaskId.fresh();
                tasks[id] := {
                    id: id,
                    projectId: pid,
                    title: draftTask.title,
                    description: draftTask.description,
                    status: Backlog,
                    priority: draftTask.priority,
                    assignee: draftTask.assignee,
                    dueDate: Time.parse(draftTask.dueDate),
                    tags: parseTags(draftTask.tags),
                    parentTaskId: None,
                    createdAt: now,
                    updatedAt: now
                };
                draftTask := {title: "", description: "", priority: Med, assignee: "", tags: "", dueDate: ""};
                emit saveTasks(tasks);
                emit navigate({path: "/projects/" + pid.show + "/tasks/" + id.show, params: {}})
            }
          | None -> ()

reducer updateTaskStatus
    on=ui.change(TaskStatusSelect)
    do= tasks[$el.taskId].status := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskPriority
    on=ui.change(TaskPrioritySelect)
    do= tasks[$el.taskId].priority := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskAssignee
    on=ui.input(TaskAssigneeInput)
    do= tasks[$el.taskId].assignee := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskDueDate
    on=ui.input(TaskDueDateInput)
    do= match Time.parse($event.value) with
          | Some(t) -> { tasks[$el.taskId].dueDate := Some(t); tasks[$el.taskId].updatedAt := now; emit saveTasks(tasks) }
          | None -> ()

reducer addTaskTag
    on=ui.submit(AddTagForm)
    do= match routeTaskId($route) with
          | Some(tid) -> {
                tasks[tid].tags := tasks[tid].tags.push(taskTagDraft);
                tasks[tid].updatedAt := now;
                taskTagDraft := "";
                emit saveTasks(tasks)
            }
          | None -> ()

reducer removeTaskTag
    on=ui.click(RemoveTagBtn)
    do= match routeTaskId($route) with
          | Some(tid) -> {
                tasks[tid].tags := tasks[tid].tags.filter($1 != $el.tag);
                tasks[tid].updatedAt := now;
                emit saveTasks(tasks)
            }
          | None -> ()

reducer updateTaskTitle
    on=ui.input(TaskTitleInput)
    do= tasks[$el.taskId].title := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskDescription
    on=ui.input(TaskDescriptionInput)
    do= tasks[$el.taskId].description := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer deleteTask
    on=ui.click(DeleteTaskBtn)
    do= match routeTaskId($route) with
          | Some(tid) -> {
                let pid = tasks[tid].projectId;
                let cids = commentsForTask(comments, tid);
                for cid in cids {
                    comments := comments.remove(cid)
                };
                tasks := tasks.remove(tid);
                emit saveTasks(tasks);
                emit saveComments(comments);
                emit navigate({path: "/projects/" + pid.show, params: {}})
            }
          | None -> ()

reducer moveTaskStatus
    on=ui.click(MoveStatusBtn)
    do= tasks[$el.taskId].status := $el.status
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer addComment
    on=ui.submit(NewCommentForm)
    do= match routeTaskId($route) with
          | Some(tid) -> {
                let id = CommentId.fresh();
                comments[id] := {
                    id: id,
                    taskId: tid,
                    author: "Current User",
                    body: commentDraft,
                    createdAt: now
                };
                commentDraft := "";
                emit saveComments(comments)
            }
          | None -> ()

reducer deleteComment
    on=ui.click(DeleteCommentBtn)
    do= comments := comments.remove($el.commentId)
        emit saveComments(comments)

reducer setFilterStatus
    on=ui.change(FilterStatusSelect)
    do= filter.status := $event.value

reducer setFilterPriority
    on=ui.change(FilterPrioritySelect)
    do= filter.priority := $event.value

reducer setFilterAssignee
    on=ui.input(FilterAssigneeInput)
    do= filter.assignee := $event.value

reducer setSearch
    on=ui.input(SearchInput)
    do= filter.search := $event.value

reducer clearFilter
    on=ui.click(ClearFilterBtn)
    do= filter := {status: None, priority: None, assignee: "", search: ""}

reducer setViewMode
    on=ui.click(ViewModeBtn)
    do= viewMode := if viewMode == ListView then BoardView else ListView

tile ThemeBtn = button(text=if themeName == "Light" then "Dark" else "Light", onClick=toggleTheme) {variant: "ghost"}

tile Nav = row(
             row(
                 link(to="/") {text: "Projects"},
                 link(to="/settings") {text: "Settings"}
             ) {gap: "md"},
             ThemeBtn
           ) {pad: "md", justify: "between", bg: "surface", border-bottom: "1px solid @colors.border"}

tile ArchiveProjectBtn = button(text="Archive", onClick=archiveProject) {projectId: $1}
tile UnarchiveProjectBtn = button(text="Unarchive", onClick=unarchiveProject) {projectId: $1}
tile DeleteProjectBtn = button(text="Delete", onClick=deleteProject) {projectId: $1, color: "danger"}

tile ProjectCard
    in=Project
    = card(
        column(
            row(
                link(to="/projects/" + $1.id.show) {text: $1.name, size: "lg", weight: "bold"},
                if $1.archived then text("Archived") {color: "muted"} else text("")
            ) {justify: "between"},
            text($1.description) {color: "muted"},
            text("Active Tasks: " + tasksForProject(tasks, $1.id).length.show),
            row(
                if $1.archived then UnarchiveProjectBtn($1.id) else ArchiveProjectBtn($1.id),
                DeleteProjectBtn($1.id)
            ) {gap: "sm"}
        ) {gap: "sm"}
      ) {pad: "md"}

tile NewProjectForm
    = form(
        panel(
            heading("New Project") {size: "md"},
            column(
                input(bind=draftProject.name, placeholder="Name", required=true),
                textarea(bind=draftProject.description, placeholder="Description"),
                row(text("Color:"), input(bind=draftProject.color, type="color")) {gap: "sm"},
                button(text="Create Project", type="submit") {bg: "primary"}
            ) {gap: "sm"}
        ) {pad: "md", bg: "surface", shadow: "sm"}
      )

tile ProjectsPage
    = page(
        Nav,
        if not ready then spinner() else column(
            heading("Projects"),
            NewProjectForm,
            grid(
                for pid in projects.keys
                  ProjectCard(projects.get-or(pid, projects[pid])) {key: pid.show}
            ) {cols: {base: 1, md: 2, lg: 3}, gap: "md"}
        ) {pad: "lg", gap: "lg"}
      )

tile FilterStatusSelect = select(value=filter.status, options=[{label: "All", value: None}, {label: "Backlog", value: Some(Backlog)}, {label: "In Progress", value: Some(InProgress)}, {label: "Review", value: Some(Review)}, {label: "Done", value: Some(Done)}], placeholder="Status", onChange=setFilterStatus)
tile FilterPrioritySelect = select(value=filter.priority, options=[{label: "All", value: None}, {label: "Low", value: Some(Low)}, {label: "Med", value: Some(Med)}, {label: "High", value: Some(High)}, {label: "Critical", value: Some(Critical)}], placeholder="Priority", onChange=setFilterPriority)
tile FilterAssigneeInput = input(value=filter.assignee, placeholder="Assignee", onInput=setFilterAssignee)
tile SearchInput = input(value=filter.search, type="search", placeholder="Search Tasks", onInput=setSearch)
tile ClearFilterBtn = button(text="Clear Filter", onClick=clearFilter) {variant: "ghost"}

tile FilterBar
    = row(
        FilterStatusSelect,
        FilterPrioritySelect,
        FilterAssigneeInput,
        SearchInput,
        ClearFilterBtn
      ) {gap: "md", pad: "md", bg: "surface", radius: "md", wrap: true}

tile ViewModeBtn = button(text=if viewMode == ListView then "Switch to Board" else "Switch to List", onClick=setViewMode)

tile MoveStatusBtn = button(text=">", onClick=moveTaskStatus) {taskId: $1, status: nextStatus($2), size: "sm", variant: "ghost"}

tile TaskCard
    in=Task
    = card(
        column(
            row(
                link(to="/projects/" + $1.projectId.show + "/tasks/" + $1.id.show) {text: $1.title, weight: "bold"},
                if $1.status != Done then MoveStatusBtn($1.id, $1.status) else text("")
            ) {justify: "between"},
            row(
                text(statusLabel($1.status)) {color: statusColor($1.status), size: "sm"},
                text(priorityLabel($1.priority)) {color: priorityColor($1.priority), size: "sm"}
            ) {gap: "sm"},
            text("Assignee: " + if $1.assignee.is-empty then "Unassigned" else $1.assignee) {size: "sm", color: "muted"},
            text("Due: " + dueDateStatus($1.dueDate)) {size: "sm", color: "muted"},
            row(
                for t in $1.tags text("#" + t) {color: "primary", size: "sm", key: t}
            ) {gap: "xs"}
        ) {gap: "xs"}
      ) {pad: "sm", shadow: "sm"}

tile TaskList
    in=List(TaskId)
    = column(
        for tid in $1
          when(tasks.has(tid), TaskCard(tasks.get-or(tid, tasks[tid])) {key: tid.show})
      ) {gap: "sm"}

tile StatusColumn
    in=Tuple(ProjectId, Status)
    = column(
        heading(statusLabel($2)) {size: "md"},
        TaskList(tasksByStatus(tasks, $1, filter, $2))
      ) {gap: "sm", pad: "sm", bg: "surface"}

tile ProjectPage
    = page(
        Nav,
        if not ready then spinner() else match currentProject(route, projects) with
          | None -> text("Project not found")
          | Some(p) -> column(
              row(
                  heading(p.name),
                  ViewModeBtn
              ) {justify: "between", align: "center"},
              text(p.description) {color: "muted"},
              link(to="/projects/" + p.id.show + "/new-task") {text: "New Task"},
              FilterBar,
              match viewMode with
                | ListView -> TaskList(filteredTasks(tasks, p.id, filter))
                | BoardView -> grid(
                    StatusColumn((p.id, Backlog)),
                    StatusColumn((p.id, InProgress)),
                    StatusColumn((p.id, Review)),
                    StatusColumn((p.id, Done))
                  ) {cols: {base: 1, lg: 4}, gap: "md"}
          ) {pad: "lg", gap: "lg"}
      )

tile NewTaskForm
    = form(
        column(
            input(bind=draftTask.title, placeholder="Title", required=true),
            textarea(bind=draftTask.description, placeholder="Description"),
            select(bind=draftTask.priority, options=[{label: "Low", value: Low}, {label: "Med", value: Med}, {label: "High", value: High}, {label: "Critical", value: Critical}]),
            input(bind=draftTask.assignee, placeholder="Assignee"),
            input(bind=draftTask.tags, placeholder="Tags (comma separated)"),
            input(bind=draftTask.dueDate, type="date"),
            button(text="Create Task", type="submit") {bg: "primary"}
        ) {gap: "md", pad: "lg"}
      )

tile NewTaskPage
    = page(
        Nav,
        column(
            heading("New Task"),
            NewTaskForm
        ) {pad: "lg", max-w: 600}
      )

tile TaskTitleInput = input(value=tasks[$1].title, id="taskTitle", onInput=updateTaskTitle) {taskId: $1}
tile TaskDescriptionInput = textarea(value=tasks[$1].description, id="taskDesc", onInput=updateTaskDescription) {taskId: $1}
tile TaskStatusSelect = select(value=tasks[$1].status, options=[{label: "Backlog", value: Backlog}, {label: "In Progress", value: InProgress}, {label: "Review", value: Review}, {label: "Done", value: Done}], onChange=updateTaskStatus) {taskId: $1}
tile TaskPrioritySelect = select(value=tasks[$1].priority, options=[{label: "Low", value: Low}, {label: "Med", value: Med}, {label: "High", value: High}, {label: "Critical", value: Critical}], onChange=updateTaskPriority) {taskId: $1}
tile TaskAssigneeInput = input(value=tasks[$1].assignee, id="taskAssignee", onInput=updateTaskAssignee) {taskId: $1}
tile TaskDueDateInput = input(value=match tasks[$1].dueDate with | Some(d) -> formatDate(d) | None -> "", type="date", id="taskDue", onInput=updateTaskDueDate) {taskId: $1}

tile AddTagForm = form(row(input(bind=taskTagDraft, placeholder="New Tag", required=true), button(text="Add", type="submit")) {gap: "sm"})
tile RemoveTagBtn = button(text="x", onClick=removeTaskTag) {tag: $1, variant: "ghost", size: "sm"}

tile TaskDetailEditor
    in=TaskId
    = column(
        heading("Task Details"),
        TaskTitleInput($1),
        TaskDescriptionInput($1),
        grid(
            column(text("Status") {weight: "bold"}, TaskStatusSelect($1)),
            column(text("Priority") {weight: "bold"}, TaskPrioritySelect($1)),
            column(text("Assignee") {weight: "bold"}, TaskAssigneeInput($1)),
            column(text("Due Date") {weight: "bold"}, TaskDueDateInput($1))
        ) {cols: 2, gap: "md"},
        column(
            text("Tags") {weight: "bold"},
            row(
                for t in tasks[$1].tags
                  row(text(t), RemoveTagBtn(t)) {gap: "xs", bg: "surface", pad: "xs", radius: "sm", key: t}
            ) {gap: "sm"},
            AddTagForm
        ) {gap: "sm"}
      ) {gap: "md"}

tile DeleteTaskBtn = button(text="Delete Task", onClick=deleteTask) {color: "danger"}

tile SubtasksList
    in=TaskId
    = column(
        heading("Subtasks") {size: "md"},
        for stid in subtasksFor(tasks, $1)
          when(tasks.has(stid), TaskCard(tasks.get-or(stid, tasks[stid])) {key: stid.show})
      ) {gap: "sm"}

tile NewCommentForm = form(column(textarea(bind=commentDraft, placeholder="Write a comment...", required=true), button(text="Comment", type="submit") {bg: "primary"}) {gap: "sm"})
tile DeleteCommentBtn = button(text="Delete", onClick=deleteComment) {commentId: $1, color: "danger", variant: "ghost", size: "sm"}

tile CommentView
    in=Comment
    = card(
        column(
            row(text($1.author) {weight: "bold"}, text(formatDate($1.createdAt)) {color: "muted"}, DeleteCommentBtn($1.id)) {justify: "between"},
            text($1.body)
        ) {gap: "sm"}
      ) {pad: "md"}

tile TaskComments
    in=TaskId
    = column(
        heading("Comments") {size: "md"},
        column(
            for cid in commentsForTask(comments, $1)
              when(comments.has(cid), CommentView(comments.get-or(cid, comments[cid])) {key: cid.show})
        ) {gap: "sm"},
        NewCommentForm
      ) {gap: "md"}

tile TaskDetailPage
    = page(
        Nav,
        if not ready then spinner() else match routeTaskId(route) with
          | None -> text("Task not found")
          | Some(tid) -> match tasks.get(tid) with
              | None -> text("Task not found")
              | Some(t) -> column(
                  row(
                      link(to="/projects/" + t.projectId.show) {text: "Back to Project"},
                      DeleteTaskBtn
                  ) {justify: "between"},
                  TaskDetailEditor(tid),
                  divider(),
                  SubtasksList(tid),
                  divider(),
                  TaskComments(tid)
              ) {pad: "lg", gap: "lg", max-w: 800}
      )

tile SettingsPage
    = page(
        Nav,
        column(
            heading("Settings"),
            row(text("Theme:"), ThemeBtn) {gap: "sm"}
        ) {pad: "lg", gap: "md"}
      )

tile NotFound = page(Nav, heading("404 Not Found"))

theme Light = {
    colors: {bg: "#ffffff", fg: "#1a1a1a", muted: "#666666", primary: "#0070f3", success: "#0a7c2f", warning: "#b07c00", danger: "#c4222a", surface: "#f7f7f7", border: "#e0e0e0"},
    spacing: {xs: "4px", sm: "8px", md: "16px", lg: "24px", xl: "40px", xxl: "64px"},
    radius: {sm: "4px", md: "8px", lg: "16px"},
    typography: {family: "system-ui, sans-serif", size: {sm: "14px", md: "16px", lg: "20px", xl: "28px", xxl: "40px"}, weight: {normal: "400", medium: "500", bold: "700"}, line-height: "1.5"},
    shadow: {sm: "0 1px 2px rgba(0,0,0,0.1)", md: "0 4px 8px rgba(0,0,0,0.1)"},
    breakpoints: {sm: "640px", md: "768px", lg: "1024px"}
}

theme Dark = {
    colors: {bg: "#1a1a1a", fg: "#ffffff", muted: "#a0a0a0", primary: "#3b82f6", success: "#10b981", warning: "#f59e0b", danger: "#ef4444", surface: "#2d2d2d", border: "#404040"},
    spacing: {xs: "4px", sm: "8px", md: "16px", lg: "24px", xl: "40px", xxl: "64px"},
    radius: {sm: "4px", md: "8px", lg: "16px"},
    typography: {family: "system-ui, sans-serif", size: {sm: "14px", md: "16px", lg: "20px", xl: "28px", xxl: "40px"}, weight: {normal: "400", medium: "500", bold: "700"}, line-height: "1.5"},
    shadow: {sm: "0 1px 2px rgba(0,0,0,0.3)", md: "0 4px 8px rgba(0,0,0,0.3)"},
    breakpoints: {sm: "640px", md: "768px", lg: "1024px"}
}

app ProjectManager
    caps = [storage.read, storage.write, nav.push, nav.replace]
    routes = {
        "/" -> ProjectsPage,
        "/projects/:id/tasks/:taskId" -> TaskDetailPage,
        "/projects/:id/new-task" -> NewTaskPage,
        "/projects/:id" -> ProjectPage,
        "/settings" -> SettingsPage,
        "/404" -> NotFound
    }
    init = [loadProjects(), loadTasks(), loadComments()]
    theme = themeName
