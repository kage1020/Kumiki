# Project Management Tool SPA — Strand v0.1

# ====== Types ======

type ProjectId = nominal Text where uuid
type TaskId = nominal Text where uuid
type CommentId = nominal Text where uuid

type Status = Backlog | InProgress | Review | Done
type Priority = Low | Med | High | Critical
type ViewMode = ListView | BoardView
type DueState = Overdue | Today | Soon | Upcoming | NoDue

type Project = {
    id: ProjectId,
    name: Text,
    description: Text,
    color: Text,
    archived: Bool,
    createdAt: Time
}

type Task = {
    id: TaskId,
    projectId: ProjectId,
    title: Text,
    description: Text,
    status: Status,
    priority: Priority,
    assignee: Text,
    dueDate: Option(Time),
    tags: List(Text),
    parentTaskId: Option(TaskId),
    createdAt: Time,
    updatedAt: Time
}

type Comment = {
    id: CommentId,
    taskId: TaskId,
    author: Text,
    body: Text,
    createdAt: Time
}

type FilterState = {
    status: Option(Status),
    priority: Option(Priority),
    assignee: Text,
    search: Text
}

type ProjectDraft = {
    name: Text,
    description: Text,
    color: Text
}

type TaskDraft = {
    title: Text,
    description: Text,
    priority: Priority,
    assignee: Text,
    tags: Text,
    dueDate: Text
}

# ====== Slots ======

slot projects : Map(ProjectId, Project) = {}
slot tasks : Map(TaskId, Task) = {}
slot comments : Map(CommentId, Comment) = {}

slot viewMode : ViewMode = ListView
slot filter : FilterState = {status: None, priority: None, assignee: "", search: ""}
slot themeName : Text = "Light"

slot draftProject : ProjectDraft = {name: "", description: "", color: "#4f46e5"}
slot draftTask : TaskDraft = {
    title: "",
    description: "",
    priority: Med,
    assignee: "",
    tags: "",
    dueDate: ""
}
slot commentDraft : Text = ""
slot ready : Bool = false

# ====== Effects ======

effect loadProjects cap=storage.read
                    in=Unit
                    out=Result(Option(Map(ProjectId, Project)), Text)
                    policy=once
                    map-request={key: "pm.projects", decode: Decoder.Json(Map(ProjectId, Project))}

effect loadTasks cap=storage.read
                 in=Unit
                 out=Result(Option(Map(TaskId, Task)), Text)
                 policy=once
                 map-request={key: "pm.tasks", decode: Decoder.Json(Map(TaskId, Task))}

effect loadComments cap=storage.read
                    in=Unit
                    out=Result(Option(Map(CommentId, Comment)), Text)
                    policy=once
                    map-request={key: "pm.comments", decode: Decoder.Json(Map(CommentId, Comment))}

effect saveProjects cap=storage.write
                    in=Map(ProjectId, Project)
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.projects", value: $1}

effect saveTasks cap=storage.write
                 in=Map(TaskId, Task)
                 out=Result(Unit, Text)
                 policy=debounce(300ms)
                 map-request={key: "pm.tasks", value: $1}

effect saveComments cap=storage.write
                    in=Map(CommentId, Comment)
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.comments", value: $1}

# ====== Pure fns ======

fn statusLabel(s: Status) -> Text
   = match s with
       | Backlog    -> "Backlog"
       | InProgress -> "In progress"
       | Review     -> "Review"
       | Done       -> "Done"

fn statusColor(s: Status) -> Text
   = match s with
       | Backlog    -> "muted"
       | InProgress -> "primary"
       | Review     -> "warning"
       | Done       -> "success"

fn priorityLabel(p: Priority) -> Text
   = match p with
       | Low      -> "Low"
       | Med      -> "Medium"
       | High     -> "High"
       | Critical -> "Critical"

fn priorityColor(p: Priority) -> Text
   = match p with
       | Low      -> "muted"
       | Med      -> "primary"
       | High     -> "warning"
       | Critical -> "danger"

fn formatDate(t: Time) -> Text
   = t.format("yyyy-MM-dd")

fn dueDateText(d: Option(Time)) -> Text
   = match d with
       | Some(t) -> formatDate(t)
       | None    -> ""

fn dueDateStatus(dueDate: Option(Time)) -> DueState
   = match dueDate with
       | None    -> NoDue
       | Some(d) -> if d < now then Overdue
                    else if d.format("yyyy-MM-dd") == now.format("yyyy-MM-dd") then Today
                    else if d < now.plus(Duration.h(72)) then Soon
                    else Upcoming

fn dueStateLabel(d: DueState) -> Text
   = match d with
       | Overdue  -> "Overdue"
       | Today    -> "Today"
       | Soon     -> "Soon"
       | Upcoming -> "Upcoming"
       | NoDue    -> "No due date"

fn dueStateColor(d: DueState) -> Text
   = match d with
       | Overdue  -> "danger"
       | Today    -> "warning"
       | Soon     -> "primary"
       | Upcoming -> "muted"
       | NoDue    -> "muted"

fn parseTags(text: Text) -> List(Text)
   = text.split(",").map($1.trim).filter(not $1.is-empty).unique

fn tagsText(tags: List(Text)) -> Text
   = tags.join(", ")

fn routeProjectId(r: Route) -> Option(ProjectId)
   = ProjectId.parse(r.params.get-or("id", ""))

fn routeTaskId(r: Route) -> Option(TaskId)
   = TaskId.parse(r.params.get-or("taskId", ""))

fn currentProject(r: Route, ps: Map(ProjectId, Project)) -> Option(Project)
   = routeProjectId(r).flat-map(ps.get($1))

fn taskBelongsToProject(t: Task, pid: ProjectId) -> Bool
   = t.projectId == pid

fn taskIsRoot(t: Task) -> Bool
   = t.parentTaskId.is-none

fn textMatches(haystack: Text, needle: Text) -> Bool
   = needle.trim.is-empty || haystack.lower.contains(needle.trim.lower)

fn tagMatches(tags: List(Text), needle: Text) -> Bool
   = needle.trim.is-empty || tags.map($1.lower).join(" ").contains(needle.trim.lower)

fn statusMatches(t: Task, f: FilterState) -> Bool
   = match f.status with
       | Some(s) -> t.status == s
       | None    -> true

fn priorityMatches(t: Task, f: FilterState) -> Bool
   = match f.priority with
       | Some(p) -> t.priority == p
       | None    -> true

fn assigneeMatches(t: Task, f: FilterState) -> Bool
   = f.assignee.trim.is-empty || t.assignee.lower.contains(f.assignee.trim.lower)

fn searchMatches(t: Task, f: FilterState) -> Bool
   = textMatches(t.title, f.search) || textMatches(t.description, f.search) || tagMatches(t.tags, f.search)

fn taskMatchesFilter(t: Task, f: FilterState) -> Bool
   = statusMatches(t, f) && priorityMatches(t, f) && assigneeMatches(t, f) && searchMatches(t, f)

fn tasksForProject(ts: Map(TaskId, Task), projectId: ProjectId) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == projectId && $2.parentTaskId.is-none)
       .sort-by(-$2.updatedAt.to-ms)
       .map($1)

fn subtasksFor(ts: Map(TaskId, Task), parentId: TaskId) -> List(TaskId)
   = ts.entries
       .filter($2.parentTaskId == Some(parentId))
       .sort-by(-$2.updatedAt.to-ms)
       .map($1)

fn filteredTasks(ts: Map(TaskId, Task), projectId: ProjectId, f: FilterState) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == projectId && $2.parentTaskId.is-none && taskMatchesFilter($2, f))
       .sort-by(-$2.updatedAt.to-ms)
       .map($1)

fn tasksByStatus(ts: Map(TaskId, Task), projectId: ProjectId, f: FilterState, status: Status) -> List(TaskId)
   = ts.entries
       .filter($2.projectId == projectId && $2.parentTaskId.is-none && $2.status == status && taskMatchesFilter($2, f))
       .sort-by(-$2.updatedAt.to-ms)
       .map($1)

fn commentsForTask(cs: Map(CommentId, Comment), taskId: TaskId) -> List(CommentId)
   = cs.entries
       .filter($2.taskId == taskId)
       .sort-by($2.createdAt.to-ms)
       .map($1)

fn projectTaskCount(ts: Map(TaskId, Task), pid: ProjectId) -> Int
   = ts.filter($2.projectId == pid).size

fn projectDoneCount(ts: Map(TaskId, Task), pid: ProjectId) -> Int
   = ts.filter($2.projectId == pid && $2.status == Done).size

fn projectOpenCount(ts: Map(TaskId, Task), pid: ProjectId) -> Int
   = ts.filter($2.projectId == pid && $2.status != Done).size

fn projectIds(ps: Map(ProjectId, Project)) -> List(ProjectId)
   = ps.entries.sort-by(-$2.createdAt.to-ms).map($1)

fn activeProjectIds(ps: Map(ProjectId, Project)) -> List(ProjectId)
   = ps.entries.filter(not $2.archived).sort-by(-$2.createdAt.to-ms).map($1)

fn archivedProjectIds(ps: Map(ProjectId, Project)) -> List(ProjectId)
   = ps.entries.filter($2.archived).sort-by(-$2.createdAt.to-ms).map($1)

fn statusOptions() -> List({label: Text, value: Status})
   = [
       {label: "Backlog", value: Backlog},
       {label: "In progress", value: InProgress},
       {label: "Review", value: Review},
       {label: "Done", value: Done}
     ]

fn priorityOptions() -> List({label: Text, value: Priority})
   = [
       {label: "Low", value: Low},
       {label: "Medium", value: Med},
       {label: "High", value: High},
       {label: "Critical", value: Critical}
     ]

fn filterStatusOptions() -> List({label: Text, value: Option(Status)})
   = [
       {label: "Any status", value: None},
       {label: "Backlog", value: Some(Backlog)},
       {label: "In progress", value: Some(InProgress)},
       {label: "Review", value: Some(Review)},
       {label: "Done", value: Some(Done)}
     ]

fn filterPriorityOptions() -> List({label: Text, value: Option(Priority)})
   = [
       {label: "Any priority", value: None},
       {label: "Low", value: Some(Low)},
       {label: "Medium", value: Some(Med)},
       {label: "High", value: Some(High)},
       {label: "Critical", value: Some(Critical)}
     ]

fn nextStatus(s: Status) -> Status
   = match s with
       | Backlog    -> InProgress
       | InProgress -> Review
       | Review     -> Done
       | Done       -> Backlog

fn viewModeLabel(v: ViewMode) -> Text
   = match v with
       | ListView  -> "List"
       | BoardView -> "Board"

fn activeVariant(cond: Bool) -> Text
   = if cond then "primary" else "ghost"

fn taskPath(t: Task) -> Text
   = "/projects/" + t.projectId.show + "/tasks/" + t.id.show

fn projectPath(p: Project) -> Text
   = "/projects/" + p.id.show

fn canSubmitProject(d: ProjectDraft) -> Bool
   = not d.name.trim.is-empty

fn canSubmitTask(d: TaskDraft) -> Bool
   = not d.title.trim.is-empty

fn canSubmitComment(body: Text) -> Bool
   = not body.trim.is-empty

fn detailTask(r: Route, ts: Map(TaskId, Task)) -> Option(Task)
   = routeTaskId(r).flat-map(ts.get($1))

fn projectIsMissing(r: Route, ps: Map(ProjectId, Project)) -> Bool
   = currentProject(r, ps).is-none

fn taskIsMissing(r: Route, ts: Map(TaskId, Task)) -> Bool
   = detailTask(r, ts).is-none

fn storageReadyLabel(ok: Bool) -> Text
   = if ok then "Local data loaded" else "Loading local data"

# ====== Lifecycle reducers ======

reducer loadAll
    on=app.start
    do= emit loadProjects()
        emit loadTasks()
        emit loadComments()

reducer projectsLoaded
    on=loadProjects.ok($data, _)
    do= projects := $data.get-or({})
        ready := true

reducer tasksLoaded
    on=loadTasks.ok($data, _)
    do= tasks := $data.get-or({})

reducer commentsLoaded
    on=loadComments.ok($data, _)
    do= comments := $data.get-or({})

reducer projectsLoadFailed
    on=loadProjects.err(_, _)
    do= ready := true

reducer tasksLoadFailed
    on=loadTasks.err(_, _)
    do= ready := true

reducer commentsLoadFailed
    on=loadComments.err(_, _)
    do= ready := true

# ====== Project reducers ======

reducer createProject
    on=ui.submit(ProjectForm)
    do= if canSubmitProject(draftProject)
        then {
          let id = ProjectId.fresh();
          projects[id] := {
            id,
            name: draftProject.name.trim,
            description: draftProject.description.trim,
            color: draftProject.color.trim,
            archived: false,
            createdAt: now
          };
          draftProject := {name: "", description: "", color: "#4f46e5"};
          emit saveProjects(projects);
          emit navigate({path: "/projects/" + id.show, params: {}, query: {}})
        }
        else ()

reducer archiveProject
    on=ui.click(ArchiveProjectBtn)
    do= projects[$el.projectId].archived := true
        emit saveProjects(projects)

reducer unarchiveProject
    on=ui.click(UnarchiveProjectBtn)
    do= projects[$el.projectId].archived := false
        emit saveProjects(projects)

reducer deleteProject
    on=ui.click(DeleteProjectBtn)
    do= let pid = $el.projectId
        comments := comments.filter(tasks.get($2.taskId).map($1.projectId != pid).get-or(false))
        tasks := tasks.filter($2.projectId != pid)
        projects := projects.remove(pid)
        emit saveComments(comments)
        emit saveTasks(tasks)
        emit saveProjects(projects)
        emit navigate({path: "/", params: {}, query: {}})

# ====== Task reducers ======

reducer createTask
    on=ui.submit(TaskForm)
    do= match routeProjectId(route) with
            | Some(pid) -> if canSubmitTask(draftTask)
                           then {
                             let id = TaskId.fresh();
                             tasks[id] := {
                               id,
                               projectId: pid,
                               title: draftTask.title.trim,
                               description: draftTask.description.trim,
                               status: Backlog,
                               priority: draftTask.priority,
                               assignee: draftTask.assignee.trim,
                               dueDate: Time.parse(draftTask.dueDate),
                               tags: parseTags(draftTask.tags),
                               parentTaskId: None,
                               createdAt: now,
                               updatedAt: now
                             };
                             draftTask := {
                               title: "",
                               description: "",
                               priority: Med,
                               assignee: "",
                               tags: "",
                               dueDate: ""
                             };
                             emit saveTasks(tasks);
                             emit navigate({path: "/projects/" + pid.show + "/tasks/" + id.show, params: {}, query: {}})
                           }
                           else ()
            | None      -> emit navigate-replace({path: "/404", params: {}, query: {}})

reducer createSubtask
    on=ui.submit(SubtaskForm)
    do= match detailTask(route, tasks) with
            | Some(parent) -> if canSubmitTask(draftTask)
                              then {
                                let id = TaskId.fresh();
                                tasks[id] := {
                                  id,
                                  projectId: parent.projectId,
                                  title: draftTask.title.trim,
                                  description: draftTask.description.trim,
                                  status: Backlog,
                                  priority: draftTask.priority,
                                  assignee: draftTask.assignee.trim,
                                  dueDate: Time.parse(draftTask.dueDate),
                                  tags: parseTags(draftTask.tags),
                                  parentTaskId: Some(parent.id),
                                  createdAt: now,
                                  updatedAt: now
                                };
                                draftTask := {
                                  title: "",
                                  description: "",
                                  priority: Med,
                                  assignee: "",
                                  tags: "",
                                  dueDate: ""
                                };
                                emit saveTasks(tasks)
                              }
                              else ()
            | None         -> ()

reducer updateTaskStatus
    on=ui.change(TaskStatusSelect)
    do= tasks[$el.taskId].status := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskPriority
    on=ui.change(TaskPrioritySelect)
    do= tasks[$el.taskId].priority := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskAssignee
    on=ui.input(TaskAssigneeInput)
    do= tasks[$el.taskId].assignee := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskDueDate
    on=ui.change(TaskDueDateInput)
    do= tasks[$el.taskId].dueDate := Time.parse($event.value)
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskTitle
    on=ui.input(TaskTitleInput)
    do= tasks[$el.taskId].title := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer updateTaskDescription
    on=ui.input(TaskDescriptionInput)
    do= tasks[$el.taskId].description := $event.value
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer addTaskTag
    on=ui.submit(AddTagForm)
    do= match detailTask(route, tasks) with
            | Some(t) -> if not draftTask.tags.trim.is-empty
                         then {
                           tasks[t.id].tags := t.tags.concat(parseTags(draftTask.tags)).unique;
                           tasks[t.id].updatedAt := now;
                           draftTask.tags := "";
                           emit saveTasks(tasks)
                         }
                         else ()
            | None    -> ()

reducer removeTaskTag
    on=ui.click(RemoveTagBtn)
    do= tasks[$el.taskId].tags := tasks[$el.taskId].tags.filter($1 != $el.tag)
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer deleteTask
    on=ui.click(DeleteTaskBtn)
    do= let tid = $el.taskId
        comments := comments.filter($2.taskId != tid)
        tasks := tasks.filter($1 != tid && $2.parentTaskId != Some(tid))
        emit saveComments(comments)
        emit saveTasks(tasks)
        emit navigate({path: "/projects/" + $el.projectId.show, params: {}, query: {}})

reducer moveTaskStatus
    on=ui.click(MoveTaskBtn)
    do= tasks[$el.taskId].status := nextStatus(tasks[$el.taskId].status)
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

# ====== Comment reducers ======

reducer addComment
    on=ui.submit(CommentForm)
    do= match routeTaskId(route) with
            | Some(tid) -> if canSubmitComment(commentDraft)
                           then {
                             let id = CommentId.fresh();
                             comments[id] := {
                               id,
                               taskId: tid,
                               author: "You",
                               body: commentDraft.trim,
                               createdAt: now
                             };
                             commentDraft := "";
                             emit saveComments(comments)
                           }
                           else ()
            | None      -> ()

reducer deleteComment
    on=ui.click(DeleteCommentBtn)
    do= comments := comments.remove($el.commentId)
        emit saveComments(comments)

# ====== UI state reducers ======

reducer setFilterStatus
    on=ui.change(FilterStatusSelect)
    do= filter.status := $event.value

reducer setFilterPriority
    on=ui.change(FilterPrioritySelect)
    do= filter.priority := $event.value

reducer setFilterAssignee
    on=ui.input(FilterAssigneeInput)
    do= filter.assignee := $event.value

reducer setSearch
    on=ui.input(SearchInput)
    do= filter.search := $event.value

reducer clearFilter
    on=ui.click(ClearFilterBtn)
    do= filter := {status: None, priority: None, assignee: "", search: ""}

reducer setViewMode
    on=ui.click(ViewModeBtn)
    do= viewMode := $el.mode

reducer toggleTheme
    on=ui.click(ThemeToggleBtn)
    do= themeName := if themeName == "Light" then "Dark" else "Light"

# ====== Shared tiles ======

tile AppNav
    = row(
        row(
          link(to="/") {text: "Projects"},
          link(to="/settings") {text: "Settings"}
        ) {gap: "md", align: "center"},
        row(
          text(storageReadyLabel(ready)) {color: "muted", size: "sm"},
          ThemeToggleBtn
        ) {gap: "sm", align: "center"})
      {justify: "between", align: "center", pad: "md", bg: "surface"}

tile ThemeToggleBtn
    = button(text=if themeName == "Light" then "Dark" else "Light", onClick=toggleTheme) {variant: "ghost"}

tile EmptyState
    in=Text
    = panel(
        column(
          heading($1) {level: 3, size: "lg"},
          text("Create work, refine it, and move it through the board.") {color: "muted"}
        ) {gap: "xs"})
      {pad: "lg", bg: "surface", radius: "md"}

tile Badge
    in={label: Text, color: Text}
    = box(text($1.label) {size: "sm", color: $1.color})
      {pad-x: "sm", pad-y: "xs", bg: "surface", radius: "pill"}

tile StatChip
    in={label: Text, value: Text}
    = column(
        text($1.value) {weight: "bold"},
        text($1.label) {size: "sm", color: "muted"})
      {gap: "xs"}

# ====== Project list tiles ======

tile ProjectNameInput
    = input(bind=draftProject.name, id="projectName", placeholder="Project name", required=true)

tile ProjectDescriptionInput
    = textarea(bind=draftProject.description, id="projectDescription", rows=3, placeholder="Describe the goal")

tile ProjectColorInput
    = input(bind=draftProject.color, id="projectColor", placeholder="#4f46e5")

tile ProjectForm
    = form(
        panel(
          column(
            heading("New project") {level: 2, size: "lg"},
            label(text="Name") {for: "projectName"},
            ProjectNameInput,
            label(text="Description") {for: "projectDescription"},
            ProjectDescriptionInput,
            label(text="Color") {for: "projectColor"},
            ProjectColorInput,
            button(text="Create project", type="submit", disabled=not canSubmitProject(draftProject)) {bg: "primary"}
          ) {gap: "sm"})
        {pad: "md", bg: "surface", radius: "md"})

tile ArchiveProjectBtn
    = button(text="Archive", onClick=archiveProject) {variant: "ghost"}

tile UnarchiveProjectBtn
    = button(text="Restore", onClick=unarchiveProject) {variant: "ghost"}

tile DeleteProjectBtn
    = button(text="Delete", onClick=deleteProject) {variant: "ghost", color: "danger"}

tile ProjectCard
    in=ProjectId
    = card(
        column(
          row(
            row(
              box(text("")) {bg: projects[$1].color, w: 12, h: 12, radius: "pill"},
              link(to=projectPath(projects[$1])) {text: projects[$1].name, size: "lg", weight: "bold"}
            ) {gap: "sm", align: "center"},
            when(projects[$1].archived, Badge({label: "Archived", color: "muted"}))
          ) {justify: "between", align: "center"},
          text(projects[$1].description) {color: "muted"},
          row(
            StatChip({label: "Open", value: projectOpenCount(tasks, $1).show}),
            StatChip({label: "Done", value: projectDoneCount(tasks, $1).show}),
            StatChip({label: "Total", value: projectTaskCount(tasks, $1).show})
          ) {gap: "lg"},
          row(
            when(not projects[$1].archived, ArchiveProjectBtn {projectId: $1}),
            when(projects[$1].archived, UnarchiveProjectBtn {projectId: $1}),
            DeleteProjectBtn {projectId: $1}
          ) {gap: "xs"})
        {gap: "md"})
      {pad: "md", bg: "surface", radius: "md", shadow: "sm"}

tile ProjectList
    = column(
        heading("Active projects") {level: 2},
        when(activeProjectIds(projects).is-empty, EmptyState("No active projects")),
        grid(
          for id in activeProjectIds(projects)
            ProjectCard(id) {key: id.show}
        ) {cols: {base: 1, md: 2}, gap: "md"},
        when(not archivedProjectIds(projects).is-empty,
          column(
            heading("Archived") {level: 2, size: "lg"},
            grid(
              for id in archivedProjectIds(projects)
                ProjectCard(id) {key: id.show}
            ) {cols: {base: 1, md: 2}, gap: "md"}
          ) {gap: "md"})
      ) {gap: "md"}

tile ProjectsPage
    = page(
        AppNav,
        column(
          row(
            column(
              heading("Projects") {size: "xxl"},
              text("Plan, track, and discuss project work in one focused workspace.") {color: "muted"}
            ) {gap: "xs"},
            link(to="/settings") {text: "Settings"}
          ) {justify: "between", align: "center"},
          grid(ProjectForm, ProjectList) {cols: {base: 1, lg: [360, 1]}, gap: "lg"}
        ) {gap: "lg", pad: "lg", max-w: 1180})

# ====== Project page tiles ======

tile ViewModeBtn
    in=ViewMode
    = button(text=viewModeLabel($1), onClick=setViewMode) {
        mode: $1,
        variant: activeVariant(viewMode == $1)
      }

tile FilterStatusSelect
    = select(value=filter.status, options=filterStatusOptions(), placeholder="Status")

tile FilterPrioritySelect
    = select(value=filter.priority, options=filterPriorityOptions(), placeholder="Priority")

tile FilterAssigneeInput
    = input(value=filter.assignee, placeholder="Assignee")

tile SearchInput
    = input(value=filter.search, type="search", placeholder="Search tasks")

tile ClearFilterBtn
    = button(text="Clear", onClick=clearFilter) {variant: "ghost"}

tile FilterBar
    = panel(
        row(
          FilterStatusSelect,
          FilterPrioritySelect,
          FilterAssigneeInput,
          SearchInput,
          ClearFilterBtn
        ) {gap: "sm", wrap: true, align: "center"})
      {pad: "md", bg: "surface", radius: "md"}

tile TaskStatusBadge
    in=Status
    = Badge({label: statusLabel($1), color: statusColor($1)})

tile TaskPriorityBadge
    in=Priority
    = Badge({label: priorityLabel($1), color: priorityColor($1)})

tile DueBadge
    in=Option(Time)
    = Badge({label: dueStateLabel(dueDateStatus($1)), color: dueStateColor(dueDateStatus($1))})

tile MoveTaskBtn
    = button(text="Move", onClick=moveTaskStatus) {variant: "ghost"}

tile TaskCard
    in=TaskId
    = card(
        column(
          row(
            link(to=taskPath(tasks[$1])) {text: tasks[$1].title, weight: "bold"},
            MoveTaskBtn {taskId: $1}
          ) {justify: "between", align: "center"},
          when(not tasks[$1].description.trim.is-empty,
            text(tasks[$1].description) {color: "muted", size: "sm"}),
          row(
            TaskStatusBadge(tasks[$1].status),
            TaskPriorityBadge(tasks[$1].priority),
            DueBadge(tasks[$1].dueDate)
          ) {gap: "xs", wrap: true},
          row(
            text(if tasks[$1].assignee.trim.is-empty then "Unassigned" else tasks[$1].assignee) {color: "muted", size: "sm"},
            text(subtasksFor(tasks, $1).length.show + " subtasks") {color: "muted", size: "sm"}
          ) {justify: "between"},
          row(
            for tag in tasks[$1].tags
              text("#" + tag) {key: tag, color: "primary", size: "sm"}
          ) {gap: "xs", wrap: true})
        {gap: "sm"})
      {pad: "md", bg: "surface", radius: "md", shadow: "sm"}

tile TaskListView
    in=ProjectId
    = column(
        when(filteredTasks(tasks, $1, filter).is-empty, EmptyState("No tasks match the current filters")),
        for id in filteredTasks(tasks, $1, filter)
          TaskCard(id) {key: id.show}
      ) {gap: "md"}

tile BoardColumn
    in={projectId: ProjectId, status: Status}
    = panel(
        column(
          row(
            heading(statusLabel($1.status)) {level: 3, size: "lg"},
            Badge({label: tasksByStatus(tasks, $1.projectId, filter, $1.status).length.show, color: statusColor($1.status)})
          ) {justify: "between", align: "center"},
          when(tasksByStatus(tasks, $1.projectId, filter, $1.status).is-empty,
            text("No tasks") {color: "muted", size: "sm"}),
          for id in tasksByStatus(tasks, $1.projectId, filter, $1.status)
            TaskCard(id) {key: id.show}
        ) {gap: "sm"})
      {pad: "md", bg: "surface", radius: "md"}

tile BoardViewTile
    in=ProjectId
    = grid(
        BoardColumn({projectId: $1, status: Backlog}),
        BoardColumn({projectId: $1, status: InProgress}),
        BoardColumn({projectId: $1, status: Review}),
        BoardColumn({projectId: $1, status: Done})
      ) {cols: {base: 1, md: 2, xl: 4}, gap: "md"}

tile ProjectToolbar
    in=Project
    = row(
        row(ViewModeBtn(ListView), ViewModeBtn(BoardView)) {gap: "xs"},
        link(to="/projects/" + $1.id.show + "/new-task") {text: "New task"}
      ) {justify: "between", align: "center"}

tile ProjectBody
    in=Project
    = column(
        row(
          column(
            heading($1.name) {size: "xxl"},
            text($1.description) {color: "muted"}
          ) {gap: "xs"},
          Badge({label: projectOpenCount(tasks, $1.id).show + " open", color: "primary"})
        ) {justify: "between", align: "center"},
        ProjectToolbar($1),
        FilterBar,
        match viewMode with
          | ListView  -> TaskListView($1.id)
          | BoardView -> BoardViewTile($1.id)
      ) {gap: "lg"}

tile ProjectPage
    = page(
        AppNav,
        column(
          link(to="/") {text: "Back to projects"},
          match currentProject(route, projects) with
            | Some(p) -> ProjectBody(p)
            | None    -> EmptyState("Project not found")
        ) {gap: "md", pad: "lg", max-w: 1280})

# ====== New task tiles ======

tile TaskTitleDraftInput
    = input(bind=draftTask.title, id="taskTitle", placeholder="Task title", required=true)

tile TaskDescriptionDraftInput
    = textarea(bind=draftTask.description, id="taskDescription", rows=6, placeholder="Details")

tile TaskPriorityDraftSelect
    = select(bind=draftTask.priority, options=priorityOptions(), placeholder="Priority")

tile TaskAssigneeDraftInput
    = input(bind=draftTask.assignee, id="taskAssignee", placeholder="Assignee")

tile TaskTagsDraftInput
    = input(bind=draftTask.tags, id="taskTags", placeholder="design, frontend, launch")

tile TaskDueDateDraftInput
    = input(bind=draftTask.dueDate, id="taskDue", type="date")

tile TaskForm
    = form(
        panel(
          column(
            label(text="Title") {for: "taskTitle"},
            TaskTitleDraftInput,
            label(text="Description") {for: "taskDescription"},
            TaskDescriptionDraftInput,
            grid(
              column(label(text="Priority"), TaskPriorityDraftSelect) {gap: "xs"},
              column(label(text="Assignee") {for: "taskAssignee"}, TaskAssigneeDraftInput) {gap: "xs"},
              column(label(text="Due date") {for: "taskDue"}, TaskDueDateDraftInput) {gap: "xs"},
              column(label(text="Tags") {for: "taskTags"}, TaskTagsDraftInput) {gap: "xs"}
            ) {cols: {base: 1, md: 2}, gap: "md"},
            button(text="Create task", type="submit", disabled=not canSubmitTask(draftTask)) {bg: "primary"}
          ) {gap: "md"})
        {pad: "md", bg: "surface", radius: "md"})

tile NewTaskPage
    = page(
        AppNav,
        column(
          link(to="/projects/" + route.params.get-or("id", "")) {text: "Back to project"},
          heading("New task") {size: "xxl"},
          TaskForm
        ) {gap: "md", pad: "lg", max-w: 760})

# ====== Task detail tiles ======

tile TaskTitleInput
    in=TaskId
    = input(value=tasks[$1].title, id="detailTitle") {taskId: $1}

tile TaskDescriptionInput
    in=TaskId
    = textarea(value=tasks[$1].description, id="detailDescription", rows=8) {taskId: $1}

tile TaskStatusSelect
    in=TaskId
    = select(value=tasks[$1].status, options=statusOptions(), placeholder="Status") {taskId: $1}

tile TaskPrioritySelect
    in=TaskId
    = select(value=tasks[$1].priority, options=priorityOptions(), placeholder="Priority") {taskId: $1}

tile TaskAssigneeInput
    in=TaskId
    = input(value=tasks[$1].assignee, id="detailAssignee", placeholder="Assignee") {taskId: $1}

tile TaskDueDateInput
    in=TaskId
    = input(value=dueDateText(tasks[$1].dueDate), id="detailDue", type="date") {taskId: $1}

tile RemoveTagBtn
    = button(text="x", onClick=removeTaskTag) {variant: "ghost"}

tile TagPill
    in={taskId: TaskId, tag: Text}
    = row(
        text("#" + $1.tag) {color: "primary", size: "sm"},
        RemoveTagBtn {taskId: $1.taskId, tag: $1.tag}
      ) {gap: "xs", align: "center"}

tile AddTagForm
    = form(
        row(
          input(bind=draftTask.tags, placeholder="Add tag"),
          button(text="Add", type="submit", disabled=draftTask.tags.trim.is-empty) {variant: "ghost"}
        ) {gap: "sm"})

tile DeleteTaskBtn
    = button(text="Delete task", onClick=deleteTask) {variant: "ghost", color: "danger"}

tile SubtaskForm
    = form(
        panel(
          column(
            heading("Add subtask") {level: 3, size: "lg"},
            TaskTitleDraftInput,
            row(TaskPriorityDraftSelect, TaskAssigneeDraftInput) {gap: "sm"},
            button(text="Add subtask", type="submit", disabled=not canSubmitTask(draftTask)) {variant: "ghost"}
          ) {gap: "sm"})
        {pad: "md", bg: "surface", radius: "md"})

tile SubtaskRow
    in=TaskId
    = row(
        link(to=taskPath(tasks[$1])) {text: tasks[$1].title, weight: "bold"},
        TaskStatusBadge(tasks[$1].status),
        TaskPriorityBadge(tasks[$1].priority)
      ) {gap: "sm", justify: "between", align: "center"}

tile SubtaskList
    in=TaskId
    = column(
        heading("Subtasks") {level: 3},
        when(subtasksFor(tasks, $1).is-empty, text("No subtasks yet") {color: "muted"}),
        for id in subtasksFor(tasks, $1)
          SubtaskRow(id) {key: id.show},
        SubtaskForm
      ) {gap: "md"}

tile CommentForm
    = form(
        column(
          textarea(bind=commentDraft, rows=3, placeholder="Add a comment"),
          button(text="Comment", type="submit", disabled=not canSubmitComment(commentDraft)) {bg: "primary"}
        ) {gap: "sm"})

tile DeleteCommentBtn
    = button(text="Delete", onClick=deleteComment) {variant: "ghost"}

tile CommentItem
    in=CommentId
    = card(
        column(
          row(
            text(comments[$1].author) {weight: "bold"},
            text(formatDate(comments[$1].createdAt)) {color: "muted", size: "sm"},
            DeleteCommentBtn {commentId: $1}
          ) {gap: "sm", justify: "between", align: "center"},
          text(comments[$1].body)
        ) {gap: "xs"})
      {pad: "md", bg: "surface", radius: "md"}

tile CommentsSection
    in=TaskId
    = column(
        heading("Comments") {level: 3},
        CommentForm,
        when(commentsForTask(comments, $1).is-empty, text("No comments yet") {color: "muted"}),
        for id in commentsForTask(comments, $1)
          CommentItem(id) {key: id.show}
      ) {gap: "md"}

tile TaskMetaPanel
    in=Task
    = panel(
        column(
          heading("Properties") {level: 3, size: "lg"},
          label(text="Status"),
          TaskStatusSelect($1.id),
          label(text="Priority"),
          TaskPrioritySelect($1.id),
          label(text="Assignee") {for: "detailAssignee"},
          TaskAssigneeInput($1.id),
          label(text="Due date") {for: "detailDue"},
          TaskDueDateInput($1.id),
          row(
            text("Created " + formatDate($1.createdAt)) {color: "muted", size: "sm"},
            text("Updated " + formatDate($1.updatedAt)) {color: "muted", size: "sm"}
          ) {gap: "sm", wrap: true},
          DeleteTaskBtn {taskId: $1.id, projectId: $1.projectId}
        ) {gap: "sm"})
      {pad: "md", bg: "surface", radius: "md"}

tile TaskEditorPanel
    in=Task
    = panel(
        column(
          label(text="Title") {for: "detailTitle"},
          TaskTitleInput($1.id),
          label(text="Description") {for: "detailDescription"},
          TaskDescriptionInput($1.id),
          heading("Tags") {level: 3, size: "lg"},
          row(
            for tag in $1.tags
              TagPill({taskId: $1.id, tag}) {key: tag}
          ) {gap: "xs", wrap: true},
          AddTagForm
        ) {gap: "sm"})
      {pad: "md", bg: "surface", radius: "md"}

tile TaskDetailBody
    in=Task
    = column(
        link(to="/projects/" + $1.projectId.show) {text: "Back to project"},
        row(
          column(
            heading($1.title) {size: "xxl"},
            text(statusLabel($1.status) + " · " + priorityLabel($1.priority)) {color: "muted"}
          ) {gap: "xs"},
          DueBadge($1.dueDate)
        ) {justify: "between", align: "center"},
        grid(
          column(TaskEditorPanel($1), SubtaskList($1.id), CommentsSection($1.id)) {gap: "md"},
          TaskMetaPanel($1)
        ) {cols: {base: 1, lg: [1, 320]}, gap: "lg"}
      ) {gap: "lg"}

tile TaskDetailPage
    = page(
        AppNav,
        column(
          match detailTask(route, tasks) with
            | Some(t) -> TaskDetailBody(t)
            | None    -> EmptyState("Task not found")
        ) {pad: "lg", max-w: 1180})

# ====== Settings tiles ======

tile ThemePreview
    = panel(
        column(
          heading("Theme") {level: 2},
          text("Current theme: " + themeName),
          row(
            box(text("Primary")) {bg: "primary", color: "bg", pad: "sm", radius: "sm"},
            box(text("Success")) {bg: "success", color: "bg", pad: "sm", radius: "sm"},
            box(text("Warning")) {bg: "warning", color: "bg", pad: "sm", radius: "sm"},
            box(text("Danger")) {bg: "danger", color: "bg", pad: "sm", radius: "sm"}
          ) {gap: "sm", wrap: true},
          ThemeToggleBtn
        ) {gap: "md"})
      {pad: "md", bg: "surface", radius: "md"}

tile StoragePanel
    = panel(
        column(
          heading("Local workspace") {level: 2},
          row(
            StatChip({label: "Projects", value: projects.size.show}),
            StatChip({label: "Tasks", value: tasks.size.show}),
            StatChip({label: "Comments", value: comments.size.show})
          ) {gap: "lg"},
          text("Project, task, and comment maps are saved to localStorage with a 300ms debounce.") {color: "muted"}
        ) {gap: "md"})
      {pad: "md", bg: "surface", radius: "md"}

tile SettingsPage
    = page(
        AppNav,
        column(
          heading("Settings") {size: "xxl"},
          grid(ThemePreview, StoragePanel) {cols: {base: 1, md: 2}, gap: "md"}
        ) {pad: "lg", gap: "lg", max-w: 980})

tile NotFound
    = page(
        AppNav,
        column(
          heading("404") {size: "xxl"},
          text("The page you requested does not exist.") {color: "muted"},
          link(to="/") {text: "Back to projects"}
        ) {gap: "md", pad: "lg", max-w: 720})

# ====== Themes ======

theme Light = {
    colors: {
        bg: "#f7f8fb",
        fg: "#15171c",
        muted: "#697386",
        primary: "#3157d5",
        success: "#0f8a4b",
        warning: "#a96900",
        danger: "#c92a2a",
        surface: "#ffffff",
        border: "#d9dee8"
    },
    spacing: {
        xs: "4px",
        sm: "8px",
        md: "16px",
        lg: "24px",
        xl: "40px",
        xxl: "64px"
    },
    radius: {
        none: "0",
        sm: "4px",
        md: "8px",
        lg: "12px",
        pill: "999px"
    },
    typography: {
        family: "Inter, system-ui, sans-serif",
        size: {
            xs: "12px",
            sm: "14px",
            md: "16px",
            lg: "20px",
            xl: "28px",
            xxl: "40px"
        },
        weight: {
            normal: "400",
            medium: "500",
            bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm: "0 1px 2px rgba(15,23,42,0.08)",
        md: "0 8px 20px rgba(15,23,42,0.10)",
        lg: "0 18px 40px rgba(15,23,42,0.14)"
    },
    breakpoints: {
        sm: "640px",
        md: "768px",
        lg: "1024px",
        xl: "1280px"
    }
}

theme Dark = {
    colors: {
        bg: "#101216",
        fg: "#f4f6fb",
        muted: "#9ba4b5",
        primary: "#7c9cff",
        success: "#39b978",
        warning: "#f4b14b",
        danger: "#ff6b6b",
        surface: "#191d24",
        border: "#2b313b"
    },
    spacing: {
        xs: "4px",
        sm: "8px",
        md: "16px",
        lg: "24px",
        xl: "40px",
        xxl: "64px"
    },
    radius: {
        none: "0",
        sm: "4px",
        md: "8px",
        lg: "12px",
        pill: "999px"
    },
    typography: {
        family: "Inter, system-ui, sans-serif",
        size: {
            xs: "12px",
            sm: "14px",
            md: "16px",
            lg: "20px",
            xl: "28px",
            xxl: "40px"
        },
        weight: {
            normal: "400",
            medium: "500",
            bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm: "0 1px 2px rgba(0,0,0,0.30)",
        md: "0 8px 20px rgba(0,0,0,0.32)",
        lg: "0 18px 40px rgba(0,0,0,0.38)"
    },
    breakpoints: {
        sm: "640px",
        md: "768px",
        lg: "1024px",
        xl: "1280px"
    }
}

# ====== App ======

app ProjectManager
    caps = [
        storage.read,
        storage.write,
        nav.push,
        nav.replace
    ]
    routes = {
        "/" -> ProjectsPage,
        "/projects/:id" -> ProjectPage,
        "/projects/:id/tasks/:taskId" -> TaskDetailPage,
        "/projects/:id/new-task" -> NewTaskPage,
        "/settings" -> SettingsPage,
        "/404" -> NotFound
    }
    init = []
    theme = themeName
    meta = {
        title: "Project Manager",
        description: "A Strand project management SPA"
    }
