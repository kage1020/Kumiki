# ====== App ======

app IssueTracker
    caps = [
        storage.read,
        storage.write,
        nav.push,
        nav.replace
    ]
    routes = {
        "/" -> IssueListPage,
        "/issues/:id" -> IssueDetailPage,
        "/new" -> NewIssuePage,
        "/settings" -> SettingsPage,
        "/404" -> NotFound
    }
    init = []
    theme = themeName
    meta = {
        title: "Issue Tracker",
        description: "A Strand issue tracker SPA",
        favicon: "/favicon.ico"
    }
