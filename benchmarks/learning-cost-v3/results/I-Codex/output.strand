        border: "#30363d"
    },
    spacing: {
        xs: "4px",
        sm: "8px",
        md: "16px",
        lg: "24px",
        xl: "40px",
        xxl: "64px"
    },
    radius: {
        none: "0",
        sm: "4px",
        md: "8px",
        lg: "12px",
        pill: "999px"
    },
    typography: {
        family: "system-ui, sans-serif",
        size: {
            xs: "12px",
            sm: "14px",
            md: "16px",
            lg: "20px",
            xl: "28px",
            xxl: "36px"
        },
        weight: {
            normal: "400",
            medium: "500",
            bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm: "0 1px 2px rgba(1,4,9,0.4)",
        md: "0 8px 24px rgba(1,4,9,0.5)"
    },
    breakpoints: {
