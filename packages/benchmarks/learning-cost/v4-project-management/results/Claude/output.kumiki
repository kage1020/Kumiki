# Project Management Tool — Asana / Linear style SPA
# 7-layer Kumiki program: type / slot / effect / reducer / tile / fn / app

# ---------------------------------------------------------------------------
# Types
# ---------------------------------------------------------------------------

type ProjectId = nominal Text where uuid
type TaskId    = nominal Text where uuid
type CommentId = nominal Text where uuid

type Status   = Backlog | InProgress | Review | Done
type Priority = Low | Med | High | Critical
type ViewMode = ListView | BoardView

type Project = {
    id: ProjectId,
    name: Text,
    description: Text,
    color: Text,
    archived: Bool,
    createdAt: Time
}

type Task = {
    id: TaskId,
    projectId: ProjectId,
    title: Text,
    description: Text,
    status: Status,
    priority: Priority,
    assignee: Text,
    dueDate: Option(Time),
    tags: List(Text),
    parentTaskId: Option(TaskId),
    createdAt: Time,
    updatedAt: Time
}

type Comment = {
    id: CommentId,
    taskId: TaskId,
    author: Text,
    body: Text,
    createdAt: Time
}

type FilterState = {
    status: Option(Status),
    priority: Option(Priority),
    assignee: Text,
    search: Text
}

type DraftProject = {
    name: Text,
    description: Text,
    color: Text
}

type DraftTask = {
    title: Text,
    description: Text,
    priority: Priority,
    assignee: Text,
    tags: Text,
    dueDate: Text
}

# ---------------------------------------------------------------------------
# Slots
# ---------------------------------------------------------------------------

slot projects : Map(ProjectId, Project) = {}
slot tasks    : Map(TaskId, Task)       = {}
slot comments : Map(CommentId, Comment) = {}

slot viewMode  : ViewMode    = ListView
slot filter    : FilterState = {status: None, priority: None, assignee: "", search: ""}
slot themeName : Text        = "Light"

slot draftProject : DraftProject = {name: "", description: "", color: "#0070f3"}
slot draftTask    : DraftTask    = {title: "", description: "", priority: Med, assignee: "", tags: "", dueDate: ""}

slot commentDraft : Text = ""
slot tagDraft     : Text = ""
slot ready        : Bool = false

# ---------------------------------------------------------------------------
# Effects
# ---------------------------------------------------------------------------

effect saveProjects cap=storage.write
                    in=Map(ProjectId, Project)
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.projects", value: $1}

effect saveTasks    cap=storage.write
                    in=Map(TaskId, Task)
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.tasks", value: $1}

effect saveComments cap=storage.write
                    in=Map(CommentId, Comment)
                    out=Result(Unit, Text)
                    policy=debounce(300ms)
                    map-request={key: "pm.comments", value: $1}

effect loadProjects cap=storage.read
                    in=Unit
                    out=Result(Option(Map(ProjectId, Project)), Text)
                    policy=once
                    map-request={key: "pm.projects", decode: Decoder.Json(Map(ProjectId, Project))}

effect loadTasks    cap=storage.read
                    in=Unit
                    out=Result(Option(Map(TaskId, Task)), Text)
                    policy=once
                    map-request={key: "pm.tasks", decode: Decoder.Json(Map(TaskId, Task))}

effect loadComments cap=storage.read
                    in=Unit
                    out=Result(Option(Map(CommentId, Comment)), Text)
                    policy=once
                    map-request={key: "pm.comments", decode: Decoder.Json(Map(CommentId, Comment))}

effect navigate     cap=nav.push
                    in={path: Text, params: Map(Text, Text), query: Map(Text, Text)}
                    out=Unit

# ---------------------------------------------------------------------------
# Pure functions — display helpers
# ---------------------------------------------------------------------------

fn statusLabel(s: Status) -> Text
   = match s with
       | Backlog    -> "Backlog"
       | InProgress -> "In Progress"
       | Review     -> "Review"
       | Done       -> "Done"

fn statusColor(s: Status) -> Text
   = match s with
       | Backlog    -> "muted"
       | InProgress -> "primary"
       | Review     -> "warning"
       | Done       -> "success"

fn priorityLabel(p: Priority) -> Text
   = match p with
       | Low      -> "Low"
       | Med      -> "Medium"
       | High     -> "High"
       | Critical -> "Critical"

fn priorityColor(p: Priority) -> Text
   = match p with
       | Low      -> "muted"
       | Med      -> "primary"
       | High     -> "warning"
       | Critical -> "danger"

fn nextStatus(s: Status) -> Status
   = match s with
       | Backlog    -> InProgress
       | InProgress -> Review
       | Review     -> Done
       | Done       -> Done

fn toggleView(v: ViewMode) -> ViewMode
   = match v with
       | ListView  -> BoardView
       | BoardView -> ListView

fn formatDate(t: Time) -> Text
   = t.format("yyyy-MM-dd")

fn dueDateRaw(due: Option(Time)) -> Text
   = match due with
       | None    -> ""
       | Some(t) -> t.format("yyyy-MM-dd")

fn dueDateText(due: Option(Time)) -> Text
   = match due with
       | None    -> "No due date"
       | Some(t) -> "Due " + formatDate(t)

fn dueDateStatus(due: Option(Time), ref: Time) -> Text
   = match due with
       | None    -> "NoDue"
       | Some(t) -> if t < ref then "Overdue"
                    else if t.diff(ref).to-ms < 86400000 then "Today"
                    else if t.diff(ref).to-ms < 259200000 then "Soon"
                    else "Upcoming"

fn dueDateColor(due: Option(Time), ref: Time) -> Text
   = match dueDateStatus(due, ref) with
       | "Overdue" -> "danger"
       | "Today"   -> "warning"
       | "Soon"    -> "primary"
       | _         -> "muted"

fn parseTags(text: Text) -> List(Text)
   = text.split(",").map($1.trim).filter(notBlank($1))

fn notBlank(s: Text) -> Bool
   = !s.is-empty

fn statusOptions() -> List({label: Text, value: Status})
   = [
       {label: "Backlog",     value: Backlog},
       {label: "In Progress", value: InProgress},
       {label: "Review",      value: Review},
       {label: "Done",        value: Done}
     ]

fn priorityOptions() -> List({label: Text, value: Priority})
   = [
       {label: "Low",      value: Low},
       {label: "Medium",   value: Med},
       {label: "High",     value: High},
       {label: "Critical", value: Critical}
     ]

# ---------------------------------------------------------------------------
# Pure functions — queries
# ---------------------------------------------------------------------------

fn matchStatus(t: Task, s: Option(Status)) -> Bool
   = match s with | None -> true | Some(v) -> t.status == v

fn matchPriority(t: Task, p: Option(Priority)) -> Bool
   = match p with | None -> true | Some(v) -> t.priority == v

fn matchesFilter(t: Task, f: FilterState) -> Bool
   = matchStatus(t, f.status)
     && matchPriority(t, f.priority)
     && (f.assignee.is-empty || t.assignee.lower.contains(f.assignee.lower))
     && (f.search.is-empty || t.title.lower.contains(f.search.lower) || t.description.lower.contains(f.search.lower))

fn isSubtaskOf(t: Task, parent: TaskId) -> Bool
   = match t.parentTaskId with | Some(p) -> p == parent | None -> false

fn isTopLevel(t: Task) -> Bool
   = t.parentTaskId.is-none

fn tasksForProject(m: Map(TaskId, Task), pid: ProjectId) -> List(TaskId)
   = m.entries.filter($2.projectId == pid).sort-by($2.updatedAt).reverse.map($1)

fn subtasksFor(m: Map(TaskId, Task), parent: TaskId) -> List(TaskId)
   = m.entries.filter(isSubtaskOf($2, parent)).sort-by($2.createdAt).map($1)

fn filteredTasks(m: Map(TaskId, Task), pid: ProjectId, f: FilterState) -> List(TaskId)
   = m.entries.filter(taskMatches($2, pid, f)).sort-by($2.updatedAt).reverse.map($1)

fn taskMatches(t: Task, pid: ProjectId, f: FilterState) -> Bool
   = t.projectId == pid && isTopLevel(t) && matchesFilter(t, f)

fn tasksByStatus(m: Map(TaskId, Task), pid: ProjectId, f: FilterState, s: Status) -> List(TaskId)
   = m.entries.filter(taskInStatus($2, pid, f, s)).sort-by($2.updatedAt).reverse.map($1)

fn taskInStatus(t: Task, pid: ProjectId, f: FilterState, s: Status) -> Bool
   = t.projectId == pid && isTopLevel(t) && t.status == s && matchesFilter(t, f)

fn commentsForTask(cs: Map(CommentId, Comment), tid: TaskId) -> List(CommentId)
   = cs.entries.filter($2.taskId == tid).sort-by($2.createdAt).map($1)

fn activeCount(m: Map(TaskId, Task), pid: ProjectId) -> Int
   = m.entries.filter(activeInProject($2, pid)).length

fn activeInProject(t: Task, pid: ProjectId) -> Bool
   = t.projectId == pid && t.status != Done

fn isFilterActive(f: FilterState) -> Bool
   = f.status.is-some || f.priority.is-some || !f.assignee.is-empty || !f.search.is-empty

# ---------------------------------------------------------------------------
# Pure functions — routing
# ---------------------------------------------------------------------------

fn routeProjectId(r: Route) -> Option(ProjectId)
   = ProjectId.parse(r.params.get-or("id", ""))

fn routeTaskId(r: Route) -> Option(TaskId)
   = TaskId.parse(r.params.get-or("taskId", ""))

fn currentProject(r: Route, ps: Map(ProjectId, Project)) -> Option(Project)
   = match routeProjectId(r) with
       | Some(pid) -> ps.get(pid)
       | None      -> None

fn currentTask(r: Route, ts: Map(TaskId, Task)) -> Option(Task)
   = match routeTaskId(r) with
       | Some(tid) -> ts.get(tid)
       | None      -> None

fn taskPath(pid: ProjectId, tid: TaskId) -> Text
   = "/projects/" + pid.show + "/tasks/" + tid.show

fn projectPath(pid: ProjectId) -> Text
   = "/projects/" + pid.show

# ---------------------------------------------------------------------------
# Reducers — lifecycle / persistence
# ---------------------------------------------------------------------------

reducer loadAll
    on=app.start
    do= emit loadProjects()
        emit loadTasks()
        emit loadComments()

reducer projectsLoaded
    on=loadProjects.ok($m, _)
    do= projects := $m.get-or({})

reducer tasksLoaded
    on=loadTasks.ok($m, _)
    do= tasks := $m.get-or({})

reducer commentsLoaded
    on=loadComments.ok($m, _)
    do= comments := $m.get-or({})
        ready := true

reducer projectsLoadErr on=loadProjects.err($e, _) do= ready := true
reducer tasksLoadErr    on=loadTasks.err($e, _)    do= ready := true
reducer commentsLoadErr on=loadComments.err($e, _) do= ready := true
reducer projectsSaveErr on=saveProjects.err($e, _) do= ()
reducer tasksSaveErr    on=saveTasks.err($e, _)    do= ()
reducer commentsSaveErr on=saveComments.err($e, _) do= ()

# ---------------------------------------------------------------------------
# Reducers — projects
# ---------------------------------------------------------------------------

reducer createProject
    on=ui.submit(NewProjectForm)
    do= let pid = ProjectId.fresh()
        projects[pid] := {
            id: pid,
            name: draftProject.name,
            description: draftProject.description,
            color: draftProject.color,
            archived: false,
            createdAt: now
        }
        draftProject := {name: "", description: "", color: "#0070f3"}
        emit saveProjects(projects)
        emit navigate({path: "/projects/{id}", params: {"id": pid.show}, query: {}})

reducer archiveProject
    on=ui.click(ArchiveBtn)
    do= projects[$el.projectId].archived := true
        emit saveProjects(projects)

reducer unarchiveProject
    on=ui.click(UnarchiveBtn)
    do= projects[$el.projectId].archived := false
        emit saveProjects(projects)

reducer deleteProject
    on=ui.click(DeleteProjectBtn)
    do= let pid = $el.projectId
        comments := comments.filter(commentOutsideProject(tasks, $2, pid))
        tasks    := tasks.filter($2.projectId != pid)
        projects := projects.remove(pid)
        emit saveProjects(projects)
        emit saveTasks(tasks)
        emit saveComments(comments)

fn commentOutsideProject(ts: Map(TaskId, Task), c: Comment, pid: ProjectId) -> Bool
   = match ts.get(c.taskId) with
       | Some(t) -> t.projectId != pid
       | None    -> true

# ---------------------------------------------------------------------------
# Reducers — tasks
# ---------------------------------------------------------------------------

reducer createTask
    on=ui.submit(NewTaskForm)
    do= match routeProjectId(route) with
          | Some(pid) -> {
              let tid = TaskId.fresh()
              tasks[tid] := {
                  id: tid,
                  projectId: pid,
                  title: draftTask.title,
                  description: draftTask.description,
                  status: Backlog,
                  priority: draftTask.priority,
                  assignee: draftTask.assignee,
                  dueDate: Time.parse(draftTask.dueDate),
                  tags: parseTags(draftTask.tags),
                  parentTaskId: None,
                  createdAt: now,
                  updatedAt: now
              }
              draftTask := {title: "", description: "", priority: Med, assignee: "", tags: "", dueDate: ""}
              emit saveTasks(tasks)
              emit navigate({path: "/projects/{id}/tasks/{taskId}", params: {"id": pid.show, "taskId": tid.show}, query: {}})
            }
          | None -> ()

reducer updateTaskStatus
    on=ui.change(TaskStatusSelect)
    do= match routeTaskId(route) with
          | Some(tid) -> { tasks[tid].status := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks) }
          | None      -> ()

reducer updateTaskPriority
    on=ui.change(TaskPrioritySelect)
    do= match routeTaskId(route) with
          | Some(tid) -> { tasks[tid].priority := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks) }
          | None      -> ()

reducer updateTaskAssignee
    on=ui.input(TaskAssigneeInput)
    do= match routeTaskId(route) with
          | Some(tid) -> { tasks[tid].assignee := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks) }
          | None      -> ()

reducer updateTaskDueDate
    on=ui.change(TaskDueInput)
    do= match routeTaskId(route) with
          | Some(tid) -> { tasks[tid].dueDate := Time.parse($event.value)
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks) }
          | None      -> ()

reducer updateTaskTitle
    on=ui.input(TaskTitleInput)
    do= match routeTaskId(route) with
          | Some(tid) -> { tasks[tid].title := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks) }
          | None      -> ()

reducer updateTaskDescription
    on=ui.input(TaskDescInput)
    do= match routeTaskId(route) with
          | Some(tid) -> { tasks[tid].description := $event.value
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks) }
          | None      -> ()

reducer addTaskTag
    on=ui.click(AddTagBtn)
    do= match routeTaskId(route) with
          | Some(tid) -> { tasks[tid].tags := tasks[tid].tags.push(tagDraft.trim).unique
                           tasks[tid].updatedAt := now
                           tagDraft := ""
                           emit saveTasks(tasks) }
          | None      -> ()

reducer removeTaskTag
    on=ui.click(RemoveTagBtn)
    do= match routeTaskId(route) with
          | Some(tid) -> { tasks[tid].tags := tasks[tid].tags.filter($1 != $el.tag)
                           tasks[tid].updatedAt := now
                           emit saveTasks(tasks) }
          | None      -> ()

reducer moveTaskStatus
    on=ui.click(MoveStatusBtn)
    do= tasks[$el.taskId].status := nextStatus(tasks[$el.taskId].status)
        tasks[$el.taskId].updatedAt := now
        emit saveTasks(tasks)

reducer deleteTask
    on=ui.click(DeleteTaskBtn)
    do= comments := comments.filter($2.taskId != $el.taskId)
        tasks := tasks.remove($el.taskId)
        emit saveTasks(tasks)
        emit saveComments(comments)
        emit navigate({path: "/projects/{id}", params: {"id": $el.projectId}, query: {}})

# ---------------------------------------------------------------------------
# Reducers — comments
# ---------------------------------------------------------------------------

reducer addComment
    on=ui.click(AddCommentBtn)
    do= match routeTaskId(route) with
          | Some(tid) -> { let cid = CommentId.fresh()
                           comments[cid] := {
                               id: cid,
                               taskId: tid,
                               author: "Me",
                               body: commentDraft,
                               createdAt: now
                           }
                           commentDraft := ""
                           emit saveComments(comments) }
          | None      -> ()

reducer deleteComment
    on=ui.click(DeleteCommentBtn)
    do= comments := comments.remove($el.commentId)
        emit saveComments(comments)

# ---------------------------------------------------------------------------
# Reducers — UI state
# ---------------------------------------------------------------------------

reducer setFilterStatus   on=ui.change(FilterStatusSelect)   do= filter.status := $event.value
reducer setFilterPriority on=ui.change(FilterPrioritySelect) do= filter.priority := $event.value
reducer setFilterAssignee on=ui.input(FilterAssigneeInput)   do= filter.assignee := $event.value
reducer setSearch         on=ui.input(SearchInput)           do= filter.search := $event.value
reducer clearFilter       on=ui.click(ClearBtn)              do= filter := {status: None, priority: None, assignee: "", search: ""}
reducer setViewMode       on=ui.click(ViewToggleBtn)         do= viewMode := toggleView(viewMode)
reducer toggleTheme       on=ui.click(ThemeToggleBtn)        do= themeName := if themeName == "Light" then "Dark" else "Light"

reducer cancelNewTask
    on=ui.click(CancelTaskBtn)
    do= match routeProjectId(route) with
          | Some(pid) -> emit navigate({path: "/projects/{id}", params: {"id": pid.show}, query: {}})
          | None      -> emit navigate({path: "/", params: {}, query: {}})

# ---------------------------------------------------------------------------
# Tiles — chrome
# ---------------------------------------------------------------------------

tile ThemeToggleBtn = button(text="Toggle Theme", onClick=toggleTheme) {variant: "ghost"}

tile TopNav = row(
                link(to="/")         {text: "Projects"},
                link(to="/settings") {text: "Settings"},
                ThemeToggleBtn
              ) {gap: "md", align: "center"}

tile AppHeader = box(
                   row(
                     heading("Kumiki PM") {level: 1, size: "xl", weight: "bold"},
                     TopNav
                   ) {gap: "lg", align: "center", justify: "between"}
                 ) {bg: "surface", pad: "md", radius: "md"}

# ---------------------------------------------------------------------------
# Tiles — Projects page
# ---------------------------------------------------------------------------

tile ProjectNameInput = input(bind=draftProject.name, type="text", placeholder="Project name", required=true)
tile ProjectDescInput = input(bind=draftProject.description, type="text", placeholder="Description")
tile ProjectColorSelect = select(
                            bind=draftProject.color,
                            options=[
                              {label: "Blue",   value: "#0070f3"},
                              {label: "Green",  value: "#0a7c2f"},
                              {label: "Orange", value: "#b07c00"},
                              {label: "Red",    value: "#c4222a"}
                            ],
                            placeholder="Color")
tile CreateProjectBtn = button(text="Create Project", type="submit") {bg: "primary", color: "bg"}

tile NewProjectForm
   = form(
       column(
         heading("New Project") {level: 2, size: "lg", weight: "bold"},
         ProjectNameInput,
         ProjectDescInput,
         ProjectColorSelect,
         CreateProjectBtn
       ) {gap: "sm"}
     ) {id: "new-project"}

tile ArchiveBtn       in=ProjectId = button(text="Archive",   onClick=archiveProject)   {variant: "ghost", projectId: $1}
tile UnarchiveBtn     in=ProjectId = button(text="Unarchive", onClick=unarchiveProject) {variant: "ghost", projectId: $1}
tile DeleteProjectBtn in=ProjectId = button(text="Delete",    onClick=deleteProject)    {variant: "ghost", color: "danger", projectId: $1}

tile ProjectCard in=ProjectId
   = card(
       column(
         row(
           heading(projects[$1].name) {level: 3, size: "lg", weight: "bold"},
           when(projects[$1].archived, text("Archived") {color: "muted", size: "sm"})
         ) {gap: "sm", align: "center", justify: "between"},
         text(projects[$1].description) {color: "muted"},
         text(activeCount(tasks, $1).show + " active tasks") {color: "muted", size: "sm"},
         row(
           link(to=projectPath($1)) {text: "Open"},
           if projects[$1].archived then UnarchiveBtn($1) else ArchiveBtn($1),
           DeleteProjectBtn($1)
         ) {gap: "sm", align: "center"}
       ) {gap: "sm"}
     ) {bg: "surface", pad: "md", radius: "md", shadow: "sm"}

tile ProjectList = column(
                     for pid in projects.keys
                       ProjectCard(pid) {key: pid.show}
                   ) {gap: "md"}

tile ProjectsPage
   = page(
       column(
         AppHeader,
         NewProjectForm,
         heading("Projects") {level: 2, size: "lg", weight: "bold"},
         when(projects.is-empty, text("No projects yet. Create one above.") {color: "muted"}),
         ProjectList
       ) {gap: "lg", pad: "md"}
     ) {title: "Projects"}

# ---------------------------------------------------------------------------
# Tiles — filter bar / view toggle
# ---------------------------------------------------------------------------

tile SearchInput          = input(value=filter.search, type="search", placeholder="Search tasks")
tile FilterAssigneeInput  = input(value=filter.assignee, type="text", placeholder="Assignee")
tile ClearBtn             = button(text="Clear", onClick=clearFilter) {variant: "ghost"}

tile FilterStatusSelect = select(
                            value=filter.status,
                            options=[
                              {label: "Any Status",  value: None},
                              {label: "Backlog",     value: Some(Backlog)},
                              {label: "In Progress", value: Some(InProgress)},
                              {label: "Review",      value: Some(Review)},
                              {label: "Done",        value: Some(Done)}
                            ],
                            placeholder="Status")

tile FilterPrioritySelect = select(
                              value=filter.priority,
                              options=[
                                {label: "Any Priority", value: None},
                                {label: "Low",          value: Some(Low)},
                                {label: "Medium",       value: Some(Med)},
                                {label: "High",         value: Some(High)},
                                {label: "Critical",     value: Some(Critical)}
                              ],
                              placeholder="Priority")

tile FilterBar = row(
                   SearchInput,
                   FilterStatusSelect,
                   FilterPrioritySelect,
                   FilterAssigneeInput,
                   when(isFilterActive(filter), ClearBtn)
                 ) {gap: "sm", align: "center", wrap: true}

tile ViewToggleBtn = button(text="Toggle View", onClick=setViewMode) {variant: "ghost"}

# ---------------------------------------------------------------------------
# Tiles — task list view
# ---------------------------------------------------------------------------

tile TaskCard in=TaskId
   = card(
       column(
         row(
           link(to=taskPath(tasks[$1].projectId, $1)) {text: tasks[$1].title},
           text(statusLabel(tasks[$1].status)) {color: statusColor(tasks[$1].status), size: "sm"}
         ) {gap: "sm", align: "center", justify: "between"},
         row(
           text(priorityLabel(tasks[$1].priority)) {color: priorityColor(tasks[$1].priority), size: "sm"},
           when(!tasks[$1].assignee.is-empty, text("@" + tasks[$1].assignee) {color: "muted", size: "sm"}),
           text(dueDateText(tasks[$1].dueDate)) {color: dueDateColor(tasks[$1].dueDate, now), size: "sm"}
         ) {gap: "sm", align: "center", wrap: true},
         when(!tasks[$1].tags.is-empty,
           text(tasks[$1].tags.map(hashTag).join(" ")) {color: "primary", size: "sm"})
       ) {gap: "xs"}
     ) {bg: "surface", pad: "sm", radius: "md", shadow: "sm"}

fn hashTag(t: Text) -> Text = "#" + t

tile TaskListView in=ProjectId
   = column(
       for tid in filteredTasks(tasks, $1, filter)
         TaskCard(tid) {key: tid.show}
     ) {gap: "sm"}

# ---------------------------------------------------------------------------
# Tiles — board view
# ---------------------------------------------------------------------------

tile MoveStatusBtn in=TaskId = button(text="Advance", onClick=moveTaskStatus) {variant: "ghost", taskId: $1}

tile BoardCard in=TaskId
   = card(
       column(
         link(to=taskPath(tasks[$1].projectId, $1)) {text: tasks[$1].title},
         row(
           text(priorityLabel(tasks[$1].priority)) {color: priorityColor(tasks[$1].priority), size: "sm"},
           text(dueDateText(tasks[$1].dueDate)) {color: dueDateColor(tasks[$1].dueDate, now), size: "sm"}
         ) {gap: "xs", align: "center", wrap: true},
         MoveStatusBtn($1)
       ) {gap: "xs"}
     ) {bg: "surface", pad: "sm", radius: "sm", shadow: "sm"}

tile BoardColumnBacklog in=ProjectId
   = column(
       heading(statusLabel(Backlog)) {level: 4, size: "md", weight: "bold", color: statusColor(Backlog)},
       for tid in tasksByStatus(tasks, $1, filter, Backlog)
         BoardCard(tid) {key: tid.show}
     ) {gap: "sm", bg: "surface", pad: "sm", radius: "md"}

tile BoardColumnInProgress in=ProjectId
   = column(
       heading(statusLabel(InProgress)) {level: 4, size: "md", weight: "bold", color: statusColor(InProgress)},
       for tid in tasksByStatus(tasks, $1, filter, InProgress)
         BoardCard(tid) {key: tid.show}
     ) {gap: "sm", bg: "surface", pad: "sm", radius: "md"}

tile BoardColumnReview in=ProjectId
   = column(
       heading(statusLabel(Review)) {level: 4, size: "md", weight: "bold", color: statusColor(Review)},
       for tid in tasksByStatus(tasks, $1, filter, Review)
         BoardCard(tid) {key: tid.show}
     ) {gap: "sm", bg: "surface", pad: "sm", radius: "md"}

tile BoardColumnDone in=ProjectId
   = column(
       heading(statusLabel(Done)) {level: 4, size: "md", weight: "bold", color: statusColor(Done)},
       for tid in tasksByStatus(tasks, $1, filter, Done)
         BoardCard(tid) {key: tid.show}
     ) {gap: "sm", bg: "surface", pad: "sm", radius: "md"}

tile TaskBoardView in=ProjectId
   = grid(
       BoardColumnBacklog($1),
       BoardColumnInProgress($1),
       BoardColumnReview($1),
       BoardColumnDone($1)
     ) {cols: 4, gap: "md"}

# ---------------------------------------------------------------------------
# Tiles — Project page
# ---------------------------------------------------------------------------

tile ProjectBody in=ProjectId
   = match viewMode with
       | ListView  -> TaskListView($1)
       | BoardView -> TaskBoardView($1)

tile ProjectView in=ProjectId
   = page(
       column(
         AppHeader,
         row(
           heading(projects[$1].name) {level: 2, size: "xl", weight: "bold"},
           ViewToggleBtn
         ) {gap: "md", align: "center", justify: "between"},
         row(
           link(to=projectPath($1) + "/new-task") {text: "New Task"},
           link(to="/") {text: "Back to Projects"}
         ) {gap: "md", align: "center"},
         FilterBar,
         ProjectBody($1)
       ) {gap: "lg", pad: "md"}
     ) {title: "Project"}

tile ProjectPage
   = match currentProject(route, projects) with
       | Some(p) -> ProjectView(p.id)
       | None    -> page(
                      column(
                        AppHeader,
                        heading("Project not found") {color: "danger"},
                        link(to="/") {text: "Home"}
                      ) {gap: "md", pad: "md"}
                    ) {title: "Not Found"}

# ---------------------------------------------------------------------------
# Tiles — New task page
# ---------------------------------------------------------------------------

tile NewTaskTitleInput = input(bind=draftTask.title, type="text", placeholder="Title", required=true)
tile NewTaskDescInput  = textarea(bind=draftTask.description, placeholder="Description") {rows: 3}
tile NewTaskPrioritySelect = select(bind=draftTask.priority, options=priorityOptions(), placeholder="Priority")
tile NewTaskAssigneeInput  = input(bind=draftTask.assignee, type="text", placeholder="Assignee")
tile NewTaskTagsInput      = input(bind=draftTask.tags, type="text", placeholder="tags, comma separated")
tile NewTaskDueInput       = input(bind=draftTask.dueDate, type="date")
tile CreateTaskBtn = button(text="Create Task", type="submit") {bg: "primary", color: "bg"}
tile CancelTaskBtn = button(text="Cancel", onClick=cancelNewTask) {variant: "ghost"}

tile NewTaskForm
   = form(
       column(
         heading("New Task") {level: 2, size: "lg", weight: "bold"},
         NewTaskTitleInput,
         NewTaskDescInput,
         row(NewTaskPrioritySelect, NewTaskAssigneeInput) {gap: "sm", wrap: true},
         row(NewTaskTagsInput, NewTaskDueInput) {gap: "sm", wrap: true},
         row(CreateTaskBtn, CancelTaskBtn) {gap: "sm"}
       ) {gap: "sm"}
     ) {id: "new-task"}

tile NewTaskPage
   = page(
       column(
         AppHeader,
         NewTaskForm
       ) {gap: "lg", pad: "md"}
     ) {title: "New Task"}

# ---------------------------------------------------------------------------
# Tiles — Task detail page
# ---------------------------------------------------------------------------

tile TaskTitleInput     in=TaskId = input(value=tasks[$1].title, type="text", placeholder="Title")
tile TaskDescInput      in=TaskId = textarea(value=tasks[$1].description, placeholder="Description") {rows: 4}
tile TaskStatusSelect   in=TaskId = select(value=tasks[$1].status,   options=statusOptions(),   placeholder="Status")
tile TaskPrioritySelect in=TaskId = select(value=tasks[$1].priority, options=priorityOptions(), placeholder="Priority")
tile TaskAssigneeInput  in=TaskId = input(value=tasks[$1].assignee, type="text", placeholder="Assignee")
tile TaskDueInput       in=TaskId = input(value=dueDateRaw(tasks[$1].dueDate), type="date")

tile RemoveTagBtn in=Text = button(text="x", onClick=removeTaskTag) {variant: "ghost", tag: $1}
tile TagChip      in=Text = row(text("#" + $1) {size: "sm"}, RemoveTagBtn($1)) {gap: "xs", align: "center", bg: "surface", pad: "xs", radius: "pill"}
tile TagInput  = input(bind=tagDraft, type="text", placeholder="Add tag")
tile AddTagBtn = button(text="Add", onClick=addTaskTag) {variant: "ghost", disabled: tagDraft.is-empty}

tile TaskTagsSection in=TaskId
   = column(
       heading("Tags") {level: 4, size: "md", weight: "bold"},
       row(for t in tasks[$1].tags TagChip(t) {key: t}) {gap: "xs", wrap: true},
       row(TagInput, AddTagBtn) {gap: "sm", align: "center"}
     ) {gap: "sm"}

tile SubtaskRow in=TaskId
   = card(
       row(
         link(to=taskPath(tasks[$1].projectId, $1)) {text: tasks[$1].title},
         text(statusLabel(tasks[$1].status)) {color: statusColor(tasks[$1].status), size: "sm"}
       ) {gap: "sm", align: "center", justify: "between"}
     ) {bg: "surface", pad: "sm", radius: "md"}

tile SubtasksSection in=TaskId
   = column(
       heading("Subtasks") {level: 4, size: "md", weight: "bold"},
       when(subtasksFor(tasks, $1).is-empty, text("No subtasks") {color: "muted", size: "sm"}),
       for stid in subtasksFor(tasks, $1)
         SubtaskRow(stid) {key: stid.show}
     ) {gap: "sm"}

tile DeleteCommentBtn in=CommentId = button(text="Delete", onClick=deleteComment) {variant: "ghost", color: "danger", commentId: $1}

tile CommentRow in=CommentId
   = card(
       column(
         row(
           text(comments[$1].author) {weight: "bold", size: "sm"},
           text(formatDate(comments[$1].createdAt)) {color: "muted", size: "sm"},
           DeleteCommentBtn($1)
         ) {gap: "sm", align: "center", justify: "between"},
         text(comments[$1].body)
       ) {gap: "xs"}
     ) {bg: "surface", pad: "sm", radius: "md"}

tile CommentInput  = textarea(bind=commentDraft, placeholder="Write a comment") {rows: 2}
tile AddCommentBtn = button(text="Add Comment", onClick=addComment) {bg: "primary", color: "bg", disabled: commentDraft.is-empty}

tile CommentsSection in=TaskId
   = column(
       heading("Comments") {level: 4, size: "md", weight: "bold"},
       row(CommentInput, AddCommentBtn) {gap: "sm", align: "end"},
       for cid in commentsForTask(comments, $1)
         CommentRow(cid) {key: cid.show}
     ) {gap: "sm"}

tile DeleteTaskBtn in=TaskId = button(text="Delete Task", onClick=deleteTask) {variant: "ghost", color: "danger", taskId: $1, projectId: tasks[$1].projectId.show}

tile TaskDetailView in=TaskId
   = page(
       column(
         AppHeader,
         row(
           link(to=projectPath(tasks[$1].projectId)) {text: "Back to Project"},
           DeleteTaskBtn($1)
         ) {gap: "md", align: "center", justify: "between"},
         TaskTitleInput($1),
         TaskDescInput($1),
         row(
           column(text("Status") {weight: "bold", size: "sm"}, TaskStatusSelect($1)) {gap: "xs"},
           column(text("Priority") {weight: "bold", size: "sm"}, TaskPrioritySelect($1)) {gap: "xs"},
           column(text("Assignee") {weight: "bold", size: "sm"}, TaskAssigneeInput($1)) {gap: "xs"},
           column(text("Due date") {weight: "bold", size: "sm"}, TaskDueInput($1)) {gap: "xs"}
         ) {gap: "md", wrap: true},
         text(dueDateStatus(tasks[$1].dueDate, now)) {color: dueDateColor(tasks[$1].dueDate, now), size: "sm"},
         TaskTagsSection($1),
         divider(),
         SubtasksSection($1),
         divider(),
         text("Created " + formatDate(tasks[$1].createdAt)) {color: "muted", size: "sm"},
         CommentsSection($1)
       ) {gap: "md", pad: "md"}
     ) {title: "Task"}

tile TaskDetailPage
   = match routeTaskId(route) with
       | Some(tid) -> if tasks.has(tid)
                        then TaskDetailView(tid)
                        else page(column(AppHeader, heading("Task not found") {color: "danger"}, link(to="/") {text: "Home"}) {gap: "md", pad: "md"}) {title: "Not Found"}
       | None      -> page(column(AppHeader, heading("Task not found") {color: "danger"}, link(to="/") {text: "Home"}) {gap: "md", pad: "md"}) {title: "Not Found"}

# ---------------------------------------------------------------------------
# Tiles — Settings page / 404
# ---------------------------------------------------------------------------

tile SettingsPage
   = page(
       column(
         AppHeader,
         heading("Settings") {level: 2, size: "lg", weight: "bold"},
         row(
           text("Theme: " + themeName),
           ThemeToggleBtn
         ) {gap: "md", align: "center"},
         link(to="/") {text: "Back to Projects"}
       ) {gap: "lg", pad: "md"}
     ) {title: "Settings"}

tile NotFound
   = page(
       column(
         heading("404") {level: 1, size: "xxl", weight: "bold"},
         text("Page not found") {color: "muted"},
         link(to="/") {text: "Home"}
       ) {gap: "md", pad: "md"}
     ) {title: "Not Found"}

# ---------------------------------------------------------------------------
# Themes
# ---------------------------------------------------------------------------

theme Light = {
    colors: {
        bg:      "#ffffff",
        fg:      "#1a1a1a",
        muted:   "#666666",
        primary: "#0070f3",
        success: "#0a7c2f",
        warning: "#b07c00",
        danger:  "#c4222a",
        surface: "#f7f7f7",
        border:  "#e0e0e0"
    },
    spacing: {
        xs: "4px", sm: "8px", md: "16px",
        lg: "24px", xl: "40px", xxl: "64px"
    },
    radius: {
        none: "0", sm: "4px", md: "8px",
        lg: "16px", pill: "999px"
    },
    typography: {
        family: "system-ui, sans-serif",
        size: {
            xs: "12px", sm: "14px", md: "16px",
            lg: "20px", xl: "28px", xxl: "40px"
        },
        weight: {
            normal: "400", medium: "500", bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm:   "0 1px 2px rgba(0,0,0,0.1)",
        md:   "0 4px 8px rgba(0,0,0,0.1)",
        lg:   "0 8px 24px rgba(0,0,0,0.15)"
    }
}

theme Dark = {
    colors: {
        bg:      "#0a0a0a",
        fg:      "#fafafa",
        muted:   "#a0a0a0",
        primary: "#3b9eff",
        success: "#3fd17b",
        warning: "#e0b040",
        danger:  "#ff5c63",
        surface: "#1a1a1a",
        border:  "#333333"
    },
    spacing: {
        xs: "4px", sm: "8px", md: "16px",
        lg: "24px", xl: "40px", xxl: "64px"
    },
    radius: {
        none: "0", sm: "4px", md: "8px",
        lg: "16px", pill: "999px"
    },
    typography: {
        family: "system-ui, sans-serif",
        size: {
            xs: "12px", sm: "14px", md: "16px",
            lg: "20px", xl: "28px", xxl: "40px"
        },
        weight: {
            normal: "400", medium: "500", bold: "700"
        },
        line-height: "1.5"
    },
    shadow: {
        none: "none",
        sm:   "0 1px 2px rgba(0,0,0,0.4)",
        md:   "0 4px 8px rgba(0,0,0,0.4)",
        lg:   "0 8px 24px rgba(0,0,0,0.5)"
    }
}

# ---------------------------------------------------------------------------
# App entry
# ---------------------------------------------------------------------------

app ProjectManagement
    caps   = [storage.read, storage.write, nav.push]
    routes = {
        "/"                            -> ProjectsPage,
        "/projects/:id"                -> ProjectPage,
        "/projects/:id/new-task"       -> NewTaskPage,
        "/projects/:id/tasks/:taskId"  -> TaskDetailPage,
        "/settings"                    -> SettingsPage,
        "/404"                         -> NotFound
    }
    init  = []
    theme = themeName
