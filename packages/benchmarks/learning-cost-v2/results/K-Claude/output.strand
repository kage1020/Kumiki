# Kanban Board — Strand v0.1
# 3 columns (Todo / Doing / Done), add / move / delete cards, localStorage persistence

# ====== Types ======

type CardId = nominal Text where uuid
type Column = Todo | Doing | Done
type Card   = {id: CardId, title: Text where nonempty, column: Column, createdAt: Time}

# ====== Slots ======

slot cards : Map(CardId, Card)         = {}
slot draft : Text where len-lt(200)    = ""
slot ready : Bool                      = false

# ====== Effects ======

effect loadCards cap=storage.read
                 in=Unit
                 out=Result(Option(Map(CardId, Card)), Text)
                 policy=once
                 map-request={key: "cards", decode: Decoder.Json(Map(CardId, Card))}

effect saveCards cap=storage.write
                 in=Map(CardId, Card)
                 out=Result(Unit, Text)
                 policy=debounce(300ms)
                 map-request={key: "cards", value: $1}

# ====== Fns ======

fn isColumn(c: Card, col: Column) -> Bool
   = c.column == col

fn cardsIn(cs: Map(CardId, Card), col: Column) -> List(CardId)
   = cs.entries
       .filter(isColumn($2, col))
       .sort-by($2.createdAt.to-ms)
       .map($1)

fn countIn(cs: Map(CardId, Card), col: Column) -> Int
   = cs.filter(isColumn($2, col)).size

fn columnLabel(col: Column) -> Text
   = match col with
       | Todo  -> "Todo"
       | Doing -> "Doing"
       | Done  -> "Done"

fn leftOf(col: Column) -> Option(Column)
   = match col with
       | Todo  -> None
       | Doing -> Some(Todo)
       | Done  -> Some(Doing)

fn rightOf(col: Column) -> Option(Column)
   = match col with
       | Todo  -> Some(Doing)
       | Doing -> Some(Done)
       | Done  -> None

fn canMoveLeft(c: Card) -> Bool
   = leftOf(c.column).is-some

fn canMoveRight(c: Card) -> Bool
   = rightOf(c.column).is-some

fn draftEmpty(d: Text) -> Bool
   = d.trim.is-empty

# ====== Reducers ======

reducer boot
    on=app.start
    do= emit loadCards()

reducer cardsLoaded
    on=loadCards.ok($m, _)
    do= cards := $m.get-or({})
        ready := true

reducer cardsLoadFailed
    on=loadCards.err(_, _)
    do= ready := true

reducer addCard
    on=ui.click(AddBtn)
    do= let id = CardId.fresh()
        cards[id] := {id, title=draft.trim, column=Todo, createdAt=now}
        draft := ""
        emit saveCards(cards)

reducer moveLeft
    on=ui.click(LeftBtn)
    do= cards[$el.cardId].column := leftOf(cards[$el.cardId].column).get-or(cards[$el.cardId].column)
        emit saveCards(cards)

reducer moveRight
    on=ui.click(RightBtn)
    do= cards[$el.cardId].column := rightOf(cards[$el.cardId].column).get-or(cards[$el.cardId].column)
        emit saveCards(cards)

reducer deleteCard
    on=ui.click(DeleteBtn)
    do= cards := cards.remove($el.cardId)
        emit saveCards(cards)

# ====== Tiles: card row ======

tile LeftBtn   = button(text="<") {variant: "ghost"}
tile RightBtn  = button(text=">") {variant: "ghost"}
tile DeleteBtn = button(text="x") {variant: "ghost", color: "danger"}

tile CardRow
    in=CardId
    = row(
        text(cards[$1].title) {size: "md"},
        row(
          LeftBtn   {cardId: $1, onClick: moveLeft,
                     disabled: not canMoveLeft(cards[$1])},
          RightBtn  {cardId: $1, onClick: moveRight,
                     disabled: not canMoveRight(cards[$1])},
          DeleteBtn {cardId: $1, onClick: deleteCard}
        ) {gap: "xs"}
      ) {gap: "sm", align: "center", justify: "between",
         pad: "sm", bg: "surface", radius: "sm", shadow: "sm"}

# ====== Tiles: column ======

tile ColumnPane
    in=Column
    = column(
        heading(columnLabel($1) + " (" + countIn(cards, $1).show + ")") {
          size: "lg", weight: "bold"
        },
        column(
          for id in cardsIn(cards, $1)
            CardRow(id) {key: id.show}
        ) {gap: "sm"}
      ) {gap: "sm", pad: "md", bg: "bg", radius: "md",
         w: "full", min-h: 300}

# ====== Tiles: add form ======

tile AddBtn = button(text="Add", onClick=addCard, disabled=draftEmpty(draft)) {
                bg: "primary", color: "bg"
              }

tile AddBar
    = row(
        input(bind=draft, placeholder="New card title", auto-focus=true) {w: "full"},
        AddBtn
      ) {gap: "sm", align: "center"}

# ====== Tiles: board ======

tile Board
    = grid(
        ColumnPane(Todo),
        ColumnPane(Doing),
        ColumnPane(Done)
      ) {cols: 3, gap: "md"}

tile App
    = page(
        heading("Kanban Board") {size: "xxl"},
        AddBar,
        when(ready, Board),
        when(not ready, spinner() {size: "lg"})
      ) {pad: "lg", gap: "md", max-w: 1200}

tile NotFound
    = page(
        heading("404"),
        link(to="/") {text: "Back"})

# ====== Theme ======

theme DefaultTheme = {
    colors: {bg: "#f4f5f7", fg: "#172b4d", muted: "#6b778c", primary: "#0052cc",
             surface: "#ffffff", border: "#dfe1e6", danger: "#de350b",
             success: "#36b37e"},
    spacing: {xs: "4px", sm: "8px", md: "16px", lg: "24px", xl: "40px", xxl: "64px"},
    radius: {sm: "4px", md: "8px", lg: "16px"},
    typography: {family: "system-ui, sans-serif",
                 size: {sm: "14px", md: "16px", lg: "20px", xl: "28px", xxl: "32px"},
                 weight: {normal: "400", medium: "500", bold: "700"},
                 line-height: "1.5"},
    shadow: {sm: "0 1px 2px rgba(0,0,0,0.08)",
             md: "0 4px 12px rgba(0,0,0,0.1)"}
}

# ====== App ======

app KanbanApp
    caps   = [storage.read, storage.write]
    routes = {"/" -> App, "/404" -> NotFound}
    init   = []
    theme  = DefaultTheme
    meta   = {title: "Strand Kanban", description: "3-column kanban board"}
